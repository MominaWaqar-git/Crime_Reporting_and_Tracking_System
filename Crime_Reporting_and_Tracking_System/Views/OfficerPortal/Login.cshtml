@model CrimeReportingSystem.Models.Officer
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Officer Portal - CrimeVision</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            body {
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                background: #050816;
                overflow: hidden;
                color: white;
            }

            /* BLOBS - Purple/Blue Swapped */
            .blob {
                position: absolute;
                border-radius: 50%;
                filter: blur(120px);
                opacity: .6;
            }

            .b1 {
                width: 400px;
                height: 400px;
                background: #2563eb;
                top: -120px;
                left: -120px;
            }
            /* Swapped to Blue */
            .b2 {
                width: 400px;
                height: 400px;
                background: #9333ea;
                bottom: -120px;
                right: -120px;
            }
            /* Swapped to Purple */

            /* HEADER */
            .header {
                position: absolute;
                top: 0;
                width: 100%;
                padding: 18px 8%;
                display: flex;
                align-items: center;
                background: rgba(255,255,255,0.05);
                backdrop-filter: blur(20px);
                border-bottom: 1px solid rgba(255,255,255,0.1);
            }

            .logo {
                font-size: 26px;
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .logo i {
                    color: #60a5fa;
                }
            
            /* Icon Blue */

            /* LOGIN BOX */
            .login-box {
                width: 420px;
                padding: 45px;
                border-radius: 30px;
                background: rgba(255,255,255,0.06);
                border: 1px solid rgba(255,255,255,0.08);
                backdrop-filter: blur(20px);
                box-shadow: 0 20px 50px rgba(0,0,0,.5);
                z-index: 2;
            }

                .login-box h2 {
                    text-align: center;
                    margin-bottom: 25px;
                    font-size: 32px;
                    font-weight: 700;
                }

            .input-box {
                position: relative;
                margin-bottom: 20px;
            }

                .input-box input {
                    width: 100%;
                    padding: 15px;
                    border-radius: 14px;
                    border: 1px solid rgba(255,255,255,0.1);
                    outline: none;
                    background: rgba(255,255,255,0.08);
                    color: white;
                    font-size: 15px;
                }

                    .input-box input:focus {
                        border-color: #2563eb;
                    }
                /* Focused Border Blue */
                .input-box i {
                    position: absolute;
                    right: 15px;
                    top: 15px;
                    color: #cbd5e1;
                }

            /* BUTTON - Swapped Gradient */
            .btn {
                width: 100%;
                padding: 15px;
                border: none;
                border-radius: 14px;
                background: linear-gradient(135deg,#9333ea,#2563eb);
                color: white;
                font-weight: 600;
                cursor: pointer;
                transition: .3s;
            }

                .btn:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3);
                }

            .back-btn {
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 10px;
                margin-top: 12px;
                padding: 12px;
                border-radius: 14px;
                text-decoration: none;
                color: white;
                background: rgba(255,255,255,0.08);
                border: 1px solid rgba(255,255,255,0.1);
                transition: .3s;
            }

                .back-btn:hover {
                    background: rgba(255,255,255,0.15);
                }

            .error {
                color: #ff6b6b;
                font-size: 13px;
                text-align: center;
                margin-top: 15px;
            }

            .footer {
                position: absolute;
                bottom: 0;
                width: 100%;
                text-align: center;
                padding: 15px;
                background: rgba(255,255,255,0.04);
                border-top: 1px solid rgba(255,255,255,0.08);
                font-size: 14px;
            }
    </style>
</head>
<body>
    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="header">
        <div class="logo"><i class="fa-solid fa-shield-halved"></i> CrimeVision</div>
    </div>

    <div class="login-box">
        <h2>Officer Login</h2>
        <form asp-controller="OfficerPortal" asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="input-box">
                @Html.TextBoxFor(x => x.CNIC, new { placeholder = "CNIC Number (13 digits)", maxlength = "13", required = "required" })
                <i class="fa-solid fa-id-card"></i>
            </div>
            <button type="submit" class="btn">Login</button>
            <a href="@Url.Action("Index", "Home")" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Back To Home</a>
            @if (ViewBag.Error != null)
            {
                <div class="error">@ViewBag.Error</div>
            }
        </form>
    </div>

    <div class="footer">© 2026 CrimeVision | Smart Crime Reporting & Tracking System</div>
</body>
</html>