@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Officer Portal Login - CrimeVision</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
            body {
                /* Landing page se exact matching dark premium gradient radial layout */
                background: radial-gradient(circle at center, #0e1731 0%, #030712 100%);
                color: #fff;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                margin: 0;
            }

            /* Top-Left Logo Styling matching landing page */
            .brand-header {
                position: absolute;
                top: 24px;
                left: 40px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .brand-logo-text {
                font-size: 22px;
                font-weight: 700;
                color: #ffffff;
                letter-spacing: 0.5px;
            }

            /* Form Card UI Wrapper with perfect matching layout */
            .login-card {
                background: #111625; /* Sleek Dark Theme matching internal panels */
                border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 20px;
                padding: 40px 35px;
                width: 100%;
                max-width: 440px;
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
            }

            .login-title {
                font-size: 28px;
                font-weight: 700;
                color: #ffffff;
                margin-bottom: 25px;
                letter-spacing: -0.5px;
            }

            /* Input Controls Setup matching form style screenshots */
            .form-control {
                background: #202635 !important;
                border: 1px solid rgba(255, 255, 255, 0.08);
                color: #ffffff !important;
                border-radius: 10px;
                font-size: 15px;
                transition: all 0.2s ease;
            }

                .form-control::placeholder {
                    color: #565e73;
                }

                .form-control:focus {
                    background: #252c3d !important;
                    border-color: #a21caf; /* Officer Theme Highlight Focus Color */
                    box-shadow: 0 0 0 3px rgba(162, 28, 175, 0.25);
                }

            /* Purple/Magenta Button styling matching landing button color blueprint */
            .btn-officer-auth {
                background: linear-gradient(135deg, #a21caf 0%, #6366f1 100%);
                border: none;
                color: white;
                font-weight: 600;
                font-size: 15px;
                border-radius: 10px;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

                .btn-officer-auth:hover {
                    transform: translateY(-1px);
                    box-shadow: 0 8px 20px rgba(162, 28, 175, 0.45);
                    color: white;
                    opacity: 0.95;
                }

            /* Return Navigation Link placement alignment */
            .btn-back-hub {
                background: #1c2230;
                border: 1px solid rgba(255, 255, 255, 0.05);
                color: #9ca3af;
                font-size: 14px;
                font-weight: 500;
                border-radius: 10px;
                transition: all 0.2s ease;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                text-decoration: none;
            }

                .btn-back-hub:hover {
                    background: #252b3a;
                    color: #ffffff;
                }

            /* Footer copy banner placement layout matching admin workspace */
            .system-footer-copyright {
                position: absolute;
                bottom: 20px;
                font-size: 13px;
                color: rgba(255, 255, 255, 0.35);
                letter-spacing: 0.3px;
            }
    </style>
</head>
<body>

    <div class="brand-header">
        <svg width="24" height="28" viewBox="0 0 24 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 0L2 4V13C2 19.2 6.3 24.9 12 26.5C17.7 24.9 22 19.2 22 13V4L12 0Z" fill="#3b82f6" />
        </svg>
        <span class="brand-logo-text">CrimeVision</span>
    </div>

    <div class="login-card text-center">

        <h2 class="login-title">Officer Login</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert text-start small mb-3 p-2.5" style="background: rgba(220, 53, 69, 0.15); border: 1px solid rgba(220, 53, 69, 0.3); color: #f87171; border-radius: 8px;" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.Error
            </div>
        }

        <form asp-controller="OfficerPortal" asp-action="Login" method="post" autocomplete="off">
            @Html.AntiForgeryToken()

            <div class="mb-4 text-start">
                <input type="text"
                       name="CNIC"
                       class="form-control py-2.5 px-3"
                       placeholder="CNIC Number (e.g., 1234567890123)"
                       maxlength="15"
                       required />
            </div>

            <button type="submit" class="btn btn-officer-auth w-100 py-2.5 mb-3">Login</button>

            <a asp-controller="Home" asp-action="Index" class="btn btn-back-hub w-100 py-2.5">
                <i class="bi bi-arrow-left"></i> Back To Home
            </a>
        </form>
    </div>

    <div class="system-footer-copyright">
        © 2026 CrimeVision | Smart Crime Reporting & Tracking System
    </div>

</body>
</html>