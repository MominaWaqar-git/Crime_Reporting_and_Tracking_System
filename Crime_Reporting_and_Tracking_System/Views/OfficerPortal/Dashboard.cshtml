@{
    Layout = null;
    string backupPhone = ViewBag.OfficerPhone?.ToString() ?? "";
}

@if (Model != null && !string.IsNullOrEmpty(Model.PhoneNumber))
{
    <a href="/Chat/OfficerPortalDesk?phone=@Model.PhoneNumber" class="btn btn-primary">
        <i class="fa-solid fa-comments"></i> Secure Communications Desk
    </a>
}
else
{
    <button class="btn btn-secondary" disabled title="Model or Phone property is null!">
        <i class="fa-solid fa-comments"></i> Chat Unavailable (Data Null)
    </button>
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Officer Dashboard - CrimeVision</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <style>
            :root {
                --blue: #2563eb;
                --purple: #9333ea;
                --cyan: #06b6d4;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            body {
                background: #050816;
                color: white;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            /* Header with Gradient Line */
            .header {
                height: 70px;
                width: 100%;
                padding: 0 5%;
                display: flex;
                align-items: center;
                justify-content: space-between;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(25px);
                border-bottom: 1px solid rgba(255,255,255,0.08);
                position: fixed;
                top: 0;
                z-index: 100;
            }

                .header::after {
                    content: "";
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    height: 2px;
                    width: 100%;
                    background: linear-gradient(90deg, var(--blue), var(--purple), var(--cyan));
                    opacity: 0.8;
                }

            .logo {
                font-size: 22px;
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .logo i {
                    color: #60a5fa;
                }

            .page-wrapper {
                display: flex;
                flex: 1;
                margin-top: 70px;
            }

            .sidebar {
                width: 260px;
                padding: 20px;
                background: rgba(255,255,255,0.03);
                border-right: 1px solid rgba(255,255,255,0.05);
                flex-shrink: 0;
            }

            .main {
                flex: 1;
                padding: 30px;
                overflow-y: auto;
                padding-bottom: 80px;
            }

            .footer {
                padding: 15px;
                text-align: center;
                background: rgba(255,255,255,0.03);
                border-top: 1px solid rgba(255,255,255,0.05);
                margin-top: auto;
            }

            .blob {
                position: fixed;
                border-radius: 50%;
                filter: blur(120px);
                opacity: .4;
                z-index: -1;
            }

            .b1 {
                width: 400px;
                height: 400px;
                background: var(--blue);
                top: -100px;
                left: -100px;
            }

            .b2 {
                width: 400px;
                height: 400px;
                background: var(--purple);
                bottom: -100px;
                right: -100px;
            }

            .avatar {
                width: 70px;
                height: 70px;
                border-radius: 50%;
                border: 3px solid var(--blue);
                margin-bottom: 10px;
            }

            .menu a {
                display: block;
                padding: 12px;
                margin: 5px 0;
                color: white;
                text-decoration: none;
                border-radius: 8px;
                transition: .3s;
            }

                .menu a.active {
                    background: linear-gradient(90deg, var(--blue), var(--purple));
                }

            .cards {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                gap: 20px;
                margin-bottom: 30px;
            }

            .card {
                padding: 20px;
                border-radius: 15px;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.1);
            }

            table {
                width: 100%;
                border-collapse: collapse;
                background: rgba(255,255,255,0.03);
                border-radius: 15px;
                overflow: hidden;
            }

            th, td {
                padding: 15px;
                border-bottom: 1px solid rgba(255,255,255,0.05);
                text-align: left;
            }

            .btn-update {
                background: var(--blue);
                border: none;
                color: white;
                padding: 6px 12px;
                border-radius: 5px;
                cursor: pointer;
            }
    </style>
</head>
<body>
    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="header">
        <div class="logo"><i class="fa-solid fa-shield-halved"></i> CrimeVision Officer</div>
    </div>

    <div class="page-wrapper">
        <div class="sidebar">
            <div style="text-align:center; margin-bottom:20px;">
                <img src="@Url.Content("~/uploads/" + ViewBag.OfficerImage)" class="avatar" />
                <h4>@ViewBag.OfficerName</h4>
                <p style="color:var(--blue); font-size:12px;">@ViewBag.OfficerRank</p>
            </div>
            <div class="menu">
                <a class="active" href="#"><i class="fa-solid fa-gauge"></i> Dashboard</a>
                <!-- Criminal Record Added Here -->
                <a asp-controller="CriminalRecord" asp-action="Index"><i class="fa-solid fa-user-secret"></i> Criminal Records</a>
                <!-- Chat Discussion Link -->
                <a asp-controller="Communication" asp-action="ChatList"><i class="fa-solid fa-comments"></i> Case Discussions</a>


                @if (!string.IsNullOrEmpty(backupPhone))
                {
                    <a href="/Chat/OfficerPortalDesk?phone=@backupPhone" class="btn btn-primary" style="background:#2563eb; color:white; margin-top:10px; text-align:center; font-weight:500; display:block; padding:12px; border-radius:8px; text-decoration:none;">
                        <i class="fa-solid fa-comments"></i> Secure Communications
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary" disabled style="width:100%; margin-top:10px; background:#374151; color:#9ca3af; border:none; padding:12px; border-radius:8px; cursor:not-allowed;" title="Backend se phone number nahi mila!">
                        <i class="fa-solid fa-lock"></i> Chat Locked (Null)
                    </button>
                }

                    <a asp-controller="OfficerPortal" asp-action="Logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
            </div>
        </div>

        <div class="main">
            <div class="cards">
                <div class="card"><h3>@ViewBag.TotalCases</h3><p>Total Assigned</p></div>
                <div class="card"><h3>@ViewBag.ActiveCases</h3><p>Active/Pending</p></div>
                <div class="card"><h3>@ViewBag.ResolvedCases</h3><p>Resolved</p></div>
            </div>

            <div style="background: rgba(255,255,255,0.05); padding: 20px; border-radius: 15px;">
                <h3>Assigned Crime Reports</h3>
                <table style="margin-top:15px;">
                    <thead><tr><th>ID</th><th>Crime</th><th>Citizen</th><th>Date</th><th>Status</th><th>Action</th></tr></thead>
                    <tbody>
                        @foreach (var item in ViewBag.Complaints)
                        {
                            var c = (IDictionary<string, object>)item;
                            <tr>
                                <td>#@c["ID"]</td>
                                <td>@c["CrimeType"]</td>
                                <td>@c["CitizenName"]</td>
                                <td>@c["IncidentDate"]</td>
                                <td>@c["Status"]</td>
                                <td>
                                    <button class="btn-update" onclick="showModal('@c["ID"]')">Update</button>
                                    <a asp-controller="OfficerPortal" asp-action="CaseDetails" asp-route-id="@c["ID"]" style="color:#60a5fa; margin-left:10px; font-weight:600;">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="footer">© 2026 CrimeVision | Smart Crime Reporting & Tracking System</div>

    <div id="statusModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:999; align-items:center; justify-content:center;">
        <div style="background:#111827; padding:30px; border-radius:15px; width:300px; border:1px solid var(--blue);">
            <h4 style="margin-bottom:15px;">Update Status</h4>
            <form asp-controller="OfficerPortal" asp-action="UpdateStatus" method="post">
                <input type="hidden" name="complaintId" id="complaintId" />
                <select name="newStatus" style="width:100%; padding:10px; background:#050816; color:white; border:1px solid #374151; border-radius:5px;">
                    <option value="Pending">Pending</option>
                    <option value="In Progress">In Progress</option>
                    <option value="Resolved">Resolved</option>
                </select>
                <div style="margin-top:20px; display:flex; gap:10px;">
                    <button type="submit" style="background:var(--blue); border:none; padding:10px; color:white; width:100%; border-radius:5px;">Save</button>
                    <button type="button" onclick="closeModal()" style="background:#374151; border:none; padding:10px; color:white; width:100%; border-radius:5px;">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script>
            function showModal(id) { document.getElementById('complaintId').value = id; document.getElementById('statusModal').style.display = 'flex'; }
            function closeModal() { document.getElementById('statusModal').style.display = 'none'; }
    </script>
</body>
</html>