@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Officer Dashboard - CrimeVision</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <style>
            :root {
                --blue: #2563eb;
                --purple: #9333ea;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            body {
                min-height: 100vh;
                background: #050816;
                color: white;
            }

            .blob {
                position: fixed;
                border-radius: 50%;
                filter: blur(120px);
                opacity: .6;
                z-index: 0;
            }

            .b1 {
                width: 450px;
                height: 450px;
                background: var(--blue);
                top: -120px;
                left: -120px;
            }

            .b2 {
                width: 450px;
                height: 450px;
                background: var(--purple);
                bottom: -120px;
                right: -120px;
            }

            .header {
                position: fixed;
                top: 0;
                width: 100%;
                padding: 18px 8%;
                display: flex;
                justify-content: space-between;
                align-items: center;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(25px);
                border-bottom: 1px solid rgba(255,255,255,0.08);
                z-index: 10;
            }

            .container {
                display: flex;
                margin-top: 80px;
                position: relative;
                z-index: 2;
            }

            .sidebar {
                width: 260px;
                min-height: calc(100vh - 80px);
                padding: 20px;
                background: rgba(255,255,255,0.05);
                backdrop-filter: blur(20px);
            }

            .menu a {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 12px;
                color: white;
                text-decoration: none;
                border-radius: 12px;
                margin-bottom: 10px;
                transition: .3s;
            }

                .menu a.active {
                    background: linear-gradient(90deg, var(--blue), var(--purple));
                }

            .main {
                flex: 1;
                padding: 30px;
            }

            .cards {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 20px;
                margin-bottom: 30px;
            }

            .card {
                padding: 20px;
                border-radius: 18px;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.1);
            }

            .table-box {
                padding: 20px;
                border-radius: 18px;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.1);
            }

            table {
                width: 100%;
                border-collapse: collapse;
            }

            th, td {
                padding: 15px;
                border-bottom: 1px solid rgba(255,255,255,0.1);
                text-align: left;
            }

            .avatar {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid var(--blue);
            }
    </style>
</head>
<body>
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="header"><div class="logo"><i class="fa-solid fa-shield-halved"></i> CrimeVision Officer</div></div>

    <div class="container">
        <div class="sidebar">
            <div class="officer-info" style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
                <img src="@Url.Content("~/uploads/" + ViewBag.OfficerImage)" class="avatar" />
                <div><div style="font-weight:600">@ViewBag.OfficerName</div><small style="color:#60a5fa">@ViewBag.OfficerRank</small></div>
            </div>
            <div class="menu">
                <a class="active" href="#"><i class="fa-solid fa-gauge"></i> Dashboard</a>
                <a asp-controller="OfficerPortal" asp-action="Logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
            </div>
        </div>

        <div class="main">
            <div class="cards">
                <div class="card"><h3>@ViewBag.TotalCases</h3><p>Total Assigned</p></div>
                <div class="card"><h3>@ViewBag.ActiveCases</h3><p>Active/Pending</p></div>
                <div class="card"><h3>@ViewBag.ResolvedCases</h3><p>Resolved</p></div>
            </div>
            <div class="table-box">
                <h3>Assigned Crime Reports</h3>
                <table>
                    <thead><tr><th>ID</th><th>Crime Type</th><th>Citizen</th><th>Date</th><th>Status</th></tr></thead>
                    <tbody>
                        @if (ViewBag.Complaints != null)
                        {
                            foreach (var item in ViewBag.Complaints)
                            {
                                var c = (IDictionary<string, object>)item;
                                <tr>
                                    <td>#@c["ID"]</td>
                                    <td>@c["CrimeType"]</td>
                                    <td>@c["CitizenName"]</td>
                                    <td>@c["IncidentDate"]</td>
                                    <td>@c["Status"]</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>