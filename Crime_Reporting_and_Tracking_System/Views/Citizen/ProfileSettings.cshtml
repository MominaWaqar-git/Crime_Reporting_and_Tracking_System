@model Crime_Reporting_and_Tracking_System.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Profile Settings - CrimeVision</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
            :root {
                --blue: #2563eb;
                --purple: #9333ea;
                --cyan: #06b6d4;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            body {
                min-height: 100vh;
                background: #050816;
                color: white;
                overflow-x: hidden;
            }

            /* BACKGROUND NEON BLOBS */
            .blob {
                position: fixed;
                border-radius: 50%;
                filter: blur(120px);
                opacity: .6;
                z-index: 0;
            }

            .b1 {
                width: 450px;
                height: 450px;
                background: var(--blue);
                top: -120px;
                left: -120px;
            }

            .b2 {
                width: 450px;
                height: 450px;
                background: var(--purple);
                bottom: -120px;
                right: -120px;
            }

            /* HEADER */
            .header {
                position: fixed;
                top: 0;
                width: 100%;
                padding: 18px 8%;
                display: flex;
                justify-content: space-between;
                align-items: center;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(25px);
                border-bottom: 1px solid rgba(255,255,255,0.08);
                z-index: 10;
            }

                .header::after {
                    content: "";
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    height: 2px;
                    width: 100%;
                    background: linear-gradient(90deg, var(--blue), var(--purple), var(--cyan));
                    opacity: 0.8;
                }

            .logo {
                font-size: 22px;
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .logo i {
                    color: #60a5fa;
                }

            /* CONTAINER LAYOUT */
            .container {
                display: flex;
                margin-top: 80px;
            }

            /* SIDEBAR */
            .sidebar {
                width: 260px;
                min-height: calc(100vh - 80px);
                padding: 20px;
                background: rgba(255,255,255,0.05);
                backdrop-filter: blur(20px);
                border-right: 1px solid rgba(255,255,255,0.08);
                z-index: 2;
            }

            .menu a {
                position: relative;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 12px;
                margin: 10px 0;
                color: white;
                text-decoration: none;
                border-radius: 12px;
                transition: .3s;
                overflow: hidden;
                font-size: 14px;
            }

                .menu a::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(90deg, rgba(37,99,235,0.25), rgba(147,51,234,0.25));
                    opacity: 0;
                    transition: .3s;
                }

                .menu a:hover::before {
                    opacity: 1;
                }

                .menu a:hover {
                    transform: translateX(8px);
                    box-shadow: 0 0 20px rgba(99,102,241,0.25);
                    background: rgba(255,255,255,0.06);
                }

                .menu a.active {
                    background: linear-gradient(90deg, var(--blue), var(--purple));
                }

            /* MAIN WORKSPACE */
            .main {
                flex: 1;
                padding: 30px;
                z-index: 2;
                margin-bottom: 60px;
            }

            .topbar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 25px;
            }

            /* NOTIFICATION MESSAGES */
            .alert-box {
                padding: 15px 20px;
                border-radius: 12px;
                margin-bottom: 25px;
                font-size: 14px;
                display: flex;
                align-items: center;
                gap: 10px;
                backdrop-filter: blur(10px);
            }

            .alert-success {
                background: rgba(16, 185, 129, 0.15);
                color: #10b981;
                border: 1px solid rgba(16, 185, 129, 0.25);
            }

            .alert-danger {
                background: rgba(239, 68, 68, 0.15);
                color: #f87171;
                border: 1px solid rgba(239, 68, 68, 0.25);
            }

            /* SETTINGS SHOWCASE CONTAINERS */
            .settings-box {
                padding: 30px;
                border-radius: 18px;
                background: rgba(255,255,255,0.03);
                border: 1px solid rgba(255,255,255,0.06);
                backdrop-filter: blur(18px);
                margin-bottom: 30px;
            }

                .settings-box h3 {
                    font-size: 18px;
                    font-weight: 600;
                    margin-bottom: 20px;
                    color: #60a5fa;
                    display: flex;
                    align-items: center;
                    gap: 8px;
                }

            /* 🛠️ PROFILE IMAGE STYLES */
            .avatar-section {
                display: flex;
                align-items: center;
                gap: 25px;
                margin-bottom: 25px;
                padding-bottom: 20px;
                border-bottom: 1px solid rgba(255,255,255,0.06);
            }

            .avatar-wrapper {
                position: relative;
                width: 110px;
                height: 110px;
                border-radius: 50%;
                padding: 3px;
                background: linear-gradient(45deg, var(--blue), var(--purple));
                box-shadow: 0 0 15px rgba(147, 51, 234, 0.3);
            }

            .avatar-wrapper img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 50%;
                background: #0d1117;
            }

            /* FORM INPUT STYLES */
            .form-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
                margin-bottom: 20px;
            }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: 8px;
            }

                .form-group label {
                    font-size: 13px;
                    color: #94a3b8;
                    font-weight: 500;
                }

            .form-control {
                padding: 12px 16px;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: 10px;
                color: white;
                font-size: 14px;
                transition: .3s;
                outline: none;
            }

                .form-control:focus {
                    border-color: #a855f7;
                    box-shadow: 0 0 15px rgba(147, 51, 234, 0.3);
                    background: rgba(255,255,255,0.08);
                }

                .form-control[readonly] {
                    background: rgba(255,255,255,0.02);
                    border-color: rgba(255,255,255,0.04);
                    color: #64748b;
                    cursor: not-allowed;
                }

            /* NEON ACTION BUTTON */
            .btn-submit {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: linear-gradient(90deg, var(--blue), var(--purple));
                color: white;
                border: none;
                padding: 12px 28px;
                border-radius: 10px;
                font-size: 14px;
                font-weight: 500;
                cursor: pointer;
                transition: .3s;
            }

                .btn-submit:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 0 20px rgba(147, 51, 234, 0.4);
                }

            /* FOOTER */
            .footer {
                position: fixed;
                bottom: 0;
                width: 100%;
                text-align: center;
                padding: 12px;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(20px);
                border-top: 1px solid rgba(255,255,255,0.08);
                z-index: 10;
                font-size: 14px;
            }
    </style>
</head>
<body>

    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="header">
        <div class="logo">
            <i class="fa-solid fa-shield-halved"></i>
            CrimeVision Citizen
        </div>
    </div>

    <div class="container">
        <div class="sidebar">
            <div class="menu">
                <a href="@Url.Action("CitizenDashboard", "Account")"><i class="fa-solid fa-gauge"></i> Dashboard</a>
                <a href="@Url.Action("MyComplaints", "Account")"><i class="fa-solid fa-file-invoice"></i> My Complaints</a>
                <a href="@Url.Action("PublicAlerts", "Account")"><i class="fa-solid fa-bullhorn"></i> Public Alerts</a>
                <a class="active" href="#"><i class="fa-solid fa-user-gear"></i> Profile Settings</a>
                <a href="@Url.Action("UserLogin", "Account")" style="color: #f87171;">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>

        <div class="main">
            <div class="topbar">
                <h2>Profile Settings</h2>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-box alert-success">
                    <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-box alert-danger">
                    <i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]
                </div>
            }

            <div class="settings-box">
                <h3><i class="fa-solid fa-user-pen"></i> Account Information</h3>
                
                <!-- 🛠️ enctype add kiya image file transfer ke liye -->
                <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                    
                    <!-- 🛠️ Profile Image Row (With Default Value Fallback) -->
                    <div class="avatar-section">
                        <div class="avatar-wrapper">
                            <img src="~/@(string.IsNullOrEmpty(Model.ProfileImage) ? "uploads/default-avatar.png" : Model.ProfileImage)" 
                                 id="avatarPreview" 
                                 alt="Profile Picture" />
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label>Profile Picture</label>
                            <input type="file" name="ProfileImageFile" id="imageUploader" class="form-control" accept="image/*" />
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" name="FullName" class="form-control" value="@Model.FullName" required />
                        </div>
                        <div class="form-group">
                            <label>Email Address</label>
                            <input type="email" name="Email" class="form-control" value="@Model.Email" required />
                        </div>
                    </div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Phone Number</label>
                            <input type="text" name="PhoneNumber" class="form-control" value="@Model.PhoneNumber" />
                        </div>
                        <div class="form-group">
                            <label>CNIC Number (Read-Only)</label>
                            <input type="text" class="form-control" value="@Model.CNIC" readonly />
                        </div>
                    </div>
                    <button type="submit" class="btn-submit">
                        <i class="fa-solid fa-floppy-disk"></i> Save Info Changes
                    </button>
                </form>
            </div>

            <div class="settings-box">
                <h3><i class="fa-solid fa-key"></i> Security & Credentials</h3>
                <form asp-action="ChangePassword" method="post">
                    <div class="form-group" style="margin-bottom: 20px;">
                        <label>Current Password</label>
                        <input type="password" name="CurrentPassword" class="form-control" required />
                    </div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>New Password</label>
                            <input type="password" name="NewPassword" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label>Confirm New Password</label>
                            <input type="password" name="ConfirmPassword" class="form-control" required />
                        </div>
                    </div>
                    <button type="submit" class="btn-submit" style="background: linear-gradient(90deg, var(--purple), var(--cyan));">
                        <i class="fa-solid fa-shield-lock"></i> Update Security Credentials
                    </button>
                </form>
            </div>

        </div>
    </div>

    <div class="footer">
        © 2026 CrimeVision | Smart Crime Reporting & Tracking System
    </div>

    <!-- 🛠️ JavaScript: Live preview functionality -->
    <script>
        document.getElementById('imageUploader').addEventListener('change', function (event) {
            const [file] = this.files;
            if (file) {
                document.getElementById('avatarPreview').src = URL.createObjectURL(file);
            }
        });
    </script>

</body>
</html>