@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>My Complaints - CrimeVision</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
            :root {
                --blue: #2563eb;
                --purple: #9333ea;
                --cyan: #06b6d4;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            body {
                min-height: 100vh;
                background: #050816;
                color: white;
                overflow-x: hidden;
            }

            /* BACKGROUND BLUR BLOBS */
            .blob {
                position: fixed;
                border-radius: 50%;
                filter: blur(120px);
                opacity: .6;
                z-index: 0;
            }

            .b1 {
                width: 450px;
                height: 450px;
                background: var(--blue);
                top: -120px;
                left: -120px;
            }

            .b2 {
                width: 450px;
                height: 450px;
                background: var(--purple);
                bottom: -120px;
                right: -120px;
            }

            /* HEADER */
            .header {
                position: fixed;
                top: 0;
                width: 100%;
                padding: 18px 8%;
                display: flex;
                justify-content: space-between;
                align-items: center;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(25px);
                border-bottom: 1px solid rgba(255,255,255,0.08);
                z-index: 10;
            }

                .header::after {
                    content: "";
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    height: 2px;
                    width: 100%;
                    background: linear-gradient(90deg, var(--blue), var(--purple), var(--cyan));
                    opacity: 0.8;
                }

            .logo {
                font-size: 22px;
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .logo i {
                    color: #60a5fa;
                }

            /* LAYOUT */
            .container {
                display: flex;
                margin-top: 80px;
            }

            /* SIDEBAR */
            .sidebar {
                width: 260px;
                min-height: calc(100vh - 80px);
                padding: 20px;
                background: rgba(255,255,255,0.05);
                backdrop-filter: blur(20px);
                border-right: 1px solid rgba(255,255,255,0.08);
                z-index: 2;
            }

            .menu a {
                position: relative;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 12px;
                margin: 10px 0;
                color: white;
                text-decoration: none;
                border-radius: 12px;
                transition: .3s;
                overflow: hidden;
                font-size: 14px;
            }

                .menu a::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(90deg, rgba(37,99,235,0.25), rgba(147,51,234,0.25));
                    opacity: 0;
                    transition: .3s;
                }

                .menu a:hover::before {
                    opacity: 1;
                }

                .menu a:hover {
                    transform: translateX(8px);
                    box-shadow: 0 0 20px rgba(99,102,241,0.25);
                    background: rgba(255,255,255,0.06);
                }

                .menu a.active {
                    background: linear-gradient(90deg, var(--blue), var(--purple));
                }

            /* MAIN WORKSPACE */
            .main {
                flex: 1;
                padding: 30px;
                z-index: 2;
                margin-bottom: 60px;
            }

            /* TOPBAR */
            .topbar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 25px;
            }

            .citizen-box {
                padding: 10px 15px;
                background: rgba(255,255,255,0.06);
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: 12px;
                backdrop-filter: blur(15px);
                font-size: 14px;
            }

            /* FORM COMPLAINT CONTAINER BOX */
            .form-box {
                padding: 25px;
                border-radius: 18px;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.1);
                backdrop-filter: blur(18px);
                margin-bottom: 30px;
            }

            .form-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 20px;
                margin-top: 15px;
            }

            .full-width {
                grid-column: span 2;
            }

            .form-group label {
                display: block;
                color: #cbd5e1;
                font-size: 13px;
                margin-bottom: 8px;
            }

            .form-control {
                width: 100%;
                background: rgba(0, 0, 0, 0.3);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 10px;
                padding: 12px;
                color: #ffffff;
                font-size: 14px;
                outline: none;
                transition: .3s;
            }

                .form-control:focus {
                    border-color: var(--cyan);
                    box-shadow: 0 0 10px rgba(6, 182, 212, 0.3);
                }

            select.form-control option {
                background: #050816;
                color: white;
            }

            .btn-submit {
                background: linear-gradient(90deg, var(--blue), var(--purple));
                color: white;
                border: none;
                border-radius: 10px;
                padding: 14px 24px;
                font-size: 14px;
                font-weight: 600;
                cursor: pointer;
                transition: .3s;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

                .btn-submit:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 0 15px rgba(147, 51, 234, 0.4);
                }

            /* TABLE CONTAINER BOX */
            .table-box {
                padding: 25px;
                border-radius: 18px;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.1);
                backdrop-filter: blur(18px);
            }

            table {
                width: 100%;
                border-collapse: collapse;
                margin-top: 15px;
            }

            th, td {
                padding: 14px 12px;
                border-bottom: 1px solid rgba(255,255,255,0.08);
                text-align: left;
                font-size: 14px;
            }

            th {
                color: var(--cyan);
                font-weight: 600;
                text-transform: uppercase;
                font-size: 12px;
                letter-spacing: 0.5px;
            }

            tr {
                transition: .3s;
            }

                tr:hover {
                    background: rgba(255,255,255,0.04);
                }

            .status {
                padding: 5px 12px;
                border-radius: 8px;
                font-size: 12px;
                font-weight: 500;
                display: inline-block;
            }

                .status.pending {
                    background: rgba(251, 191, 36, 0.2);
                    color: #fbbf24;
                    border: 1px solid rgba(251, 191, 36, 0.3);
                }

                .status.progress {
                    background: rgba(59, 130, 246, 0.2);
                    color: #60a5fa;
                    border: 1px solid rgba(59, 130, 246, 0.3);
                }

                .status.resolved {
                    background: rgba(34, 197, 94, 0.2);
                    color: #4ade80;
                    border: 1px solid rgba(34, 197, 94, 0.3);
                }

            /* FOOTER */
            .footer {
                position: fixed;
                bottom: 0;
                width: 100%;
                text-align: center;
                padding: 12px;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(20px);
                border-top: 1px solid rgba(255,255,255,0.08);
                z-index: 10;
                font-size: 14px;
            }
    </style>
</head>

<body>

    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="header">
        <div class="logo">
            <i class="fa-solid fa-shield-halved"></i>
            CrimeVision Citizen
        </div>
    </div>

    <div class="container">

        <div class="sidebar">
            <div class="menu">
                <a href="@Url.Action("CitizenDashboard", "Account")"><i class="fa-solid fa-gauge"></i> Dashboard</a>
                <a class="active" href="@Url.Action("MyComplaints", "Account")"><i class="fa-solid fa-file-invoice"></i> My Complaints</a>
                <a href="@Url.Action("PublicAlerts", "Account")"><i class="fa-solid fa-bullhorn"></i> Public Alerts</a>
                <a href="#"><i class="fa-solid fa-user-gear"></i> Profile Settings</a>
                <a href="@Url.Action("UserLogin", "Account")" style="color: #f87171;">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>

        <div class="main">

            <div class="topbar">
                <h2>Manage Complaints</h2>
                <div class="citizen-box">
                    Welcome, Citizen
                </div>
            </div>

            <div class="form-box">
                <h3 style="display: flex; align-items: center; gap: 8px;">
                    <i class="fa-solid fa-pen-to-square" style="color: var(--cyan);"></i> Lodge Official Complaint / Incident Report
                </h3>

                <!-- NOTE: enctype added for file uploading support -->
                <form asp-action="SubmitComplaint" asp-controller="Account" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="form-grid">
                        
                        <div class="form-group">
                            <label>Incident Category / Type</label>
                            <select class="form-control" name="CrimeType" required>
                                <option value="">-- Select Crime Type --</option>
                                <option value="Theft">Theft / Robbery</option>
                                <option value="Cyber Crime">Cyber Crime</option>
                                <option value="Assault">Assault</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Incident Date & Time</label>
                            <input type="datetime-local" class="form-control" name="IncidentDate" required />
                        </div>

                        <div class="form-group full-width">
                            <label>Exact Location / Area of Incident</label>
                            <input type="text" class="form-control" name="Location" placeholder="e.g. Street 4, Phase II, Kahuta" required />
                        </div>

                        <div class="form-group full-width">
                            <label>Detailed Description of the Event</label>
                            <textarea class="form-control" name="Description" rows="5" placeholder="Provide complete sequence of the event, any identifiable marks, or suspect details..." required></textarea>
                        </div>

                        <!-- NEWLY ADDED EVIDENCE UPLOAD FIELD -->
                        <div class="form-group full-width">
                            <label><i class="fa-solid fa-paperclip" style="color: var(--cyan);"></i> Upload Proof / Evidence File (Optional)</label>
                            <input type="file" class="form-control" name="EvidenceFile" style="padding: 8px;" />
                        </div>

                        <div class="form-group full-width" style="margin-top: 10px;">
                            <button type="submit" class="btn-submit">
                                <i class="fa-solid fa-paper-plane"></i> Submit Encrypted Report
                            </button>
                        </div>

                    </div>
                </form>
            </div>

            <div class="table-box">
                <h3 style="display: flex; align-items: center; gap: 8px;">
                    <i class="fa-solid fa-list-check" style="color: var(--purple);"></i> All Your Filed Case Records
                </h3>

                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Crime Type</th>
                            <th>Location</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.Complaints != null)
                        {
                            foreach (var complaint in ViewBag.Complaints)
                            {
                                var row = complaint as System.Data.DataRow;
                                var cId = row != null ? row["ID"] : complaint.ID;
                                var cType = row != null ? row["CrimeType"] : complaint.CrimeType;
                                var cLocation = row != null ? row["Location"] : complaint.Location;
                                var cStatus = row != null ? row["Status"]?.ToString() : complaint.Status?.ToString();

                                string statusClass = "pending";
                                if (!string.IsNullOrEmpty(cStatus))
                                {
                                    if (cStatus.Equals("In Progress", StringComparison.OrdinalIgnoreCase) || cStatus.Equals("progress", StringComparison.OrdinalIgnoreCase))
                                    {
                                        statusClass = "progress";
                                    }
                                    else if (cStatus.Equals("Resolved", StringComparison.OrdinalIgnoreCase))
                                    {
                                        statusClass = "resolved";
                                    }
                                }

                                <tr>
                                    <td>@cId</td>
                                    <td>@cType</td>
                                    <td>@cLocation</td>
                                    <td><span class="status @statusClass">@cStatus</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" style="text-align: center; color: var(--text-muted); opacity: 0.6;">
                                    No records found in your tracking registry.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

    <div class="footer">
        © 2026 CrimeVision | Smart Crime Reporting & Tracking System
    </div>

</body>
</html>