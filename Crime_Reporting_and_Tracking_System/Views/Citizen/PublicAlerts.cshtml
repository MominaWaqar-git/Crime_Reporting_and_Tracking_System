@{
    Layout = null; 
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Public Security Alerts - CrimeVision</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
            :root {
                --blue: #2563eb;
                --purple: #9333ea;
                --cyan: #06b6d4;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            body {
                min-height: 100vh;
                background: #050816;
                color: white;
                overflow-x: hidden;
            }

            /* BACKGROUND NEON BLOBS MATCHED */
            .blob {
                position: fixed;
                border-radius: 50%;
                filter: blur(120px);
                opacity: .6;
                z-index: 0;
            }

            .b1 {
                width: 450px;
                height: 450px;
                background: var(--blue);
                top: -120px;
                left: -120px;
            }

            .b2 {
                width: 450px;
                height: 450px;
                background: var(--purple);
                bottom: -120px;
                right: -120px;
            }

            /* HEADER MATCHED */
            .header {
                position: fixed;
                top: 0;
                width: 100%;
                padding: 18px 8%;
                display: flex;
                justify-content: space-between;
                align-items: center;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(25px);
                border-bottom: 1px solid rgba(255,255,255,0.08);
                z-index: 10;
            }

                .header::after {
                    content: "";
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    height: 2px;
                    width: 100%;
                    background: linear-gradient(90deg, var(--blue), var(--purple), var(--cyan));
                    opacity: 0.8;
                }

            .logo {
                font-size: 22px;
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .logo i {
                    color: #60a5fa;
                }

            /* CONTAINER LAYOUT MATCHED */
            .container {
                display: flex;
                margin-top: 80px;
            }

            /* SIDEBAR MATCHED */
            .sidebar {
                width: 260px;
                min-height: calc(100vh - 80px);
                padding: 20px;
                background: rgba(255,255,255,0.05);
                backdrop-filter: blur(20px);
                border-right: 1px solid rgba(255,255,255,0.08);
                z-index: 2;
            }

            .menu a {
                position: relative;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 12px;
                margin: 10px 0;
                color: white;
                text-decoration: none;
                border-radius: 12px;
                transition: .3s;
                overflow: hidden;
                font-size: 14px;
                if-index: 2;
            }

                .menu a::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(90deg, rgba(37,99,235,0.25), rgba(147,51,234,0.25));
                    opacity: 0;
                    transition: .3s;
                }

                .menu a:hover::before {
                    opacity: 1;
                }

                .menu a:hover {
                    transform: translateX(8px);
                    box-shadow: 0 0 20px rgba(99,102,241,0.25);
                    background: rgba(255,255,255,0.06);
                }

                .menu a.active {
                    background: linear-gradient(90deg, var(--blue), var(--purple));
                }

            /* MAIN WORKSPACE MATCHED */
            .main {
                flex: 1;
                padding: 30px;
                z-index: 2;
                margin-bottom: 60px;
            }

            /* TOPBAR STYLE */
            .topbar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 25px;
            }

            .welcome-box {
                padding: 10px 20px;
                background: rgba(255,255,255,0.06);
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: 12px;
                backdrop-filter: blur(15px);
                font-size: 14px;
            }

            /* SHOWCASE BOX MATCHED WITH DASHBOARD CLEAR TRANSLUCENT GLASS EFFECT */
            .showcase-box {
                padding: 30px;
                border-radius: 18px;
                background: rgba(255,255,255,0.03);
                border: 1px solid rgba(255,255,255,0.06);
                backdrop-filter: blur(18px);
            }

            /* PUBLIC ALERTS CARDS LAYOUT */
            .alerts-layout-grid {
                display: grid;
                grid-template-columns: 1fr;
                gap: 20px;
                margin-top: 15px;
            }

            .custom-alert-card {
                background: rgba(255, 255, 255, 0.02);
                border: 1px solid rgba(255, 255, 255, 0.05);
                border-radius: 14px;
                padding: 20px;
                transition: .3s;
            }

                .custom-alert-card:hover {
                    transform: translateY(-3px);
                    border-color: rgba(255, 255, 255, 0.15);
                    background: rgba(255, 255, 255, 0.04);
                }

            /* PRIORITY BADGES DYNAMIC COLORING */
            .priority-badge {
                display: inline-block;
                padding: 4px 10px;
                border-radius: 6px;
                font-size: 11px;
                font-weight: 500;
                text-transform: uppercase;
                margin-bottom: 12px;
                letter-spacing: 0.5px;
            }

            .p-high {
                background: rgba(248, 113, 113, 0.15);
                color: #f87171;
                border: 1px solid rgba(248, 113, 113, 0.25);
            }

            .p-medium {
                background: rgba(245, 158, 11, 0.15);
                color: #f59e0b;
                border: 1px solid rgba(245, 158, 11, 0.25);
            }

            .p-low {
                background: rgba(6, 182, 212, 0.15);
                color: #22d3ee;
                border: 1px solid rgba(6, 182, 212, 0.25);
            }

            .card-alert-title {
                font-size: 18px;
                font-weight: 600;
                color: #ffffff;
                margin-bottom: 8px;
            }

            .card-alert-desc {
                color: #94a3b8;
                font-size: 14px;
                line-height: 1.6;
                margin-bottom: 15px;
            }

            .card-alert-meta {
                display: flex;
                justify-content: space-between;
                align-items: center;
                font-size: 13px;
                color: #64748b;
                border-top: 1px solid rgba(255, 255, 255, 0.05);
                padding-top: 12px;
            }

            .meta-item-group {
                display: flex;
                align-items: center;
                gap: 6px;
                color: #94a3b8;
            }

                .meta-item-group i {
                    color: #06b6d4;
                }

            .link-details {
                color: #60a5fa;
                text-decoration: none;
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 6px;
                transition: 0.2s;
            }

                .link-details:hover {
                    color: #93c5fd;
                    transform: translateX(3px);
                }

            /* EMPTY STATE PATTERN MATCHED WITH DASHBOARD STYLE */
            .empty-state {
                max-width: 500px;
                margin: 0 auto;
                text-align: center;
                padding: 30px 0;
            }

                .empty-state i {
                    font-size: 55px;
                    color: rgba(16, 185, 129, 0.25); /* Subtle emerald secure shield tint */
                    margin-bottom: 20px;
                }

                .empty-state h4 {
                    font-size: 18px;
                    font-weight: 600;
                    margin-bottom: 10px;
                    color: #e2e8f0;
                }

                .empty-state p {
                    font-size: 14px;
                    color: #94a3b8;
                    line-height: 1.6;
                }

            /* FOOTER MATCHED */
            .footer {
                position: fixed;
                bottom: 0;
                width: 100%;
                text-align: center;
                padding: 12px;
                background: rgba(255,255,255,0.04);
                backdrop-filter: blur(20px);
                border-top: 1px solid rgba(255,255,255,0.08);
                z-index: 10;
                font-size: 14px;
            }
    </style>
</head>
<body>

    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="header">
        <div class="logo">
            <i class="fa-solid fa-shield-halved"></i>
            CrimeVision Citizen
        </div>
    </div>

    <div class="container">
        <div class="sidebar">
            <div class="menu">
                <a href="@Url.Action("CitizenDashboard", "Account")"><i class="fa-solid fa-gauge"></i> Dashboard</a>
                <a href="@Url.Action("MyComplaints", "Account")"><i class="fa-solid fa-file-invoice"></i> My Complaints</a>
                <a class="active" href="@Url.Action("PublicAlerts", "Account")"><i class="fa-solid fa-bullhorn"></i> Public Alerts</a>
                <a href="#"><i class="fa-solid fa-user-gear"></i> Profile Settings</a>
                <a href="@Url.Action("UserLogin", "Account")" style="color: #f87171;">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>

        <div class="main">
            <div class="topbar">
                <h2>Security Advisories</h2>
                <div class="welcome-box">
                    Welcome, Citizen
                </div>
            </div>

            <div class="showcase-box">
                @if (ViewBag.Alerts != null && ((List<dynamic>)ViewBag.Alerts).Count > 0)
                {
                    <h3 style="margin-bottom: 20px; font-size: 16px; font-weight: 500; color: #94a3b8;">Active Public Threat Metrics</h3>
                    <div class="alerts-layout-grid">
                        @foreach (var alert in ViewBag.Alerts)
                        {
                            var alertData = alert as IDictionary<string, object>;
                            string level = alertData["AlertLevel"]?.ToString() ?? "Low";
                            string badgeColorClass = "p-low";

                            if (level.Equals("High", StringComparison.OrdinalIgnoreCase) || level.Equals("Critical", StringComparison.OrdinalIgnoreCase))
                            {
                                badgeColorClass = "p-high";
                            }
                            else if (level.Equals("Medium", StringComparison.OrdinalIgnoreCase))
                            {
                                badgeColorClass = "p-medium";
                            }

                            <div class="custom-alert-card">
                                <span class="priority-badge @badgeColorClass">@level Priority</span>
                                <h3 class="card-alert-title">@alertData["Title"]</h3>
                                <p class="card-alert-desc">
                                    @if (alertData["Description"]?.ToString()?.Length > 140)
                                    {
                                        @(alertData["Description"].ToString().Substring(0, 137) + "...")
                                    }
                                    else
                                    {
                                        @alertData["Description"]
                                    }
                                </p>

                                <div class="card-alert-meta">
                                    <div style="display: flex; gap: 20px;">
                                        <div class="meta-item-group">
                                            <i class="fa-solid fa-location-dot"></i>
                                            <span>@alertData["Location"]</span>
                                        </div>
                                        <div class="meta-item-group">
                                            <i class="fa-solid fa-calendar-days"></i>
                                            <span>@alertData["DateCreated"]</span>
                                        </div>
                                    </div>

                                    <a href="@Url.Action("AlertDetails", "Account", new { id = alertData["ID"] })" class="link-details">
                                        View Details <i class="fa-solid fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fa-solid fa-shield-halved"></i>
                        <h4>No Active Security Threats</h4>
                        <p>No active security threats reported for your area. Stay safe!</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="footer">
        © 2026 CrimeVision | Smart Crime Reporting & Tracking System
    </div>

</body>
</html>