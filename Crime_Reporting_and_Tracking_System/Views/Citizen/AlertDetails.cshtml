@{
    Layout = null;
    var alert = ViewBag.SelectedAlert;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alert Details - CrimeVision</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-dark: #050816;
            --panel-bg: rgba(255, 255, 255, 0.04);
            --border-glow: rgba(255, 255, 255, 0.08);
            --text-muted: #94a3b8;
            
            /* Alert Level Colors */
            --Critical: #ef4444;
            --High: #f97316;
            --Informational: #10b981;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        body { min-height: 100vh; background: var(--bg-dark); color: white; display: flex; justify-content: center; align-items: center; padding: 20px; }

        .detail-box {
            width: 100%;
            max-width: 650px;
            padding: 40px;
            border-radius: 20px;
            background: var(--panel-bg);
            border: 1px solid var(--border-glow);
            backdrop-filter: blur(20px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
            position: relative;
        }

        /* Dynamic Border Accent based on Alert Level */
        .detail-box::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; height: 5px;
            border-top-left-radius: 20px; border-top-right-radius: 20px;
            background: var(--@alert.AlertLevel);
        }

        .header-section { margin-bottom: 25px; }
        .badge {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 15px;
            background: rgba(255,255,255,0.1);
            border: 1px solid;
            color: var(--@alert.AlertLevel);
            border-color: var(--@alert.AlertLevel);
        }

        h1 { font-size: 26px; font-weight: 600; line-height: 1.4; color: #f8fafc; }
        
        .meta-info {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            font-size: 13px;
            color: var(--text-muted);
        }
        .meta-info span i { margin-right: 6px; }

        .description-panel {
            background: rgba(0, 0, 0, 0.2);
            padding: 25px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.02);
            margin-bottom: 30px;
        }
        .description-panel h4 { font-size: 14px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
        .description-panel p { font-size: 15px; line-height: 1.8; color: #e2e8f0; white-space: pre-line; }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 24px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            color: white;
            text-decoration: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            transition: 0.3s;
        }
        .btn-back:hover { background: rgba(255,255,255,0.12); transform: translateX(-3px); }
    </style>
</head>
<body>

    <div class="detail-box">
        <div class="header-section">
            <span class="badge">@alert.AlertLevel</span>
            <h1>@alert.Title</h1>
        </div>

        <div class="meta-info">
            <span><i class="fa-solid fa-location-dot"></i> @alert.Location</span>
            <span><i class="fa-solid fa-calendar-days"></i> @alert.DateCreated</span>
        </div>

        <div class="description-panel">
            <h4>Incident Overview & Instructions</h4>
            <p>@alert.Description</p>
        </div>

        <a href="@Url.Action("PublicAlerts", "Account")" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> Back to Main Alerts
        </a>
    </div>

</body>
</html>