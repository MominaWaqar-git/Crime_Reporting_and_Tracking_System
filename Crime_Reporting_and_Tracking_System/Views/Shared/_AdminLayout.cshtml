<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"] - CrimeVision</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
            :root {
                --blue: #2563eb;
                --purple: #9333ea;
                --cyan: #06b6d4;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            body {
                min-height: 100vh;
                background: #050816; /* Same exact dark base as login */
                color: white;
                overflow-x: hidden;
            }

            /* BACKGROUND BLUR BLOBS (Exact match with Admin Login) */
            .blob {
                position: fixed;
                border-radius: 50%;
                filter: blur(120px);
                opacity: .6;
                z-index: 0;
            }

            .b1 {
                width: 450px;
                height: 450px;
                background: var(--blue);
                top: -120px;
                left: -120px;
            }

            .b2 {
                width: 450px;
                height: 450px;
                background: var(--purple);
                bottom: -120px;
                right: -120px;
            }

            /* HEADER (Synchronized with Login styling) */
            .header {
                position: fixed;
                top: 0;
                width: 100%;
                padding: 18px 8%;
                display: flex;
                justify-content: space-between;
                align-items: center;
                background: rgba(255, 255, 255, 0.05);
                backdrop-filter: blur(20px);
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                z-index: 10;
            }

            .logo {
                font-size: 22px;
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .logo i {
                    color: #60a5fa;
                }

            /* LAYOUT CONTAINER */
        .container {
            display: flex;
            margin-top: 80px;
            min-height: calc(100vh - 80px);
        }

            /* SIDEBAR (Premium Glassmorphism match) */
        .sidebar {
            width: 260px;
            min-height: calc(100vh - 80px);
            height: auto;
            padding: 20px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            position: sticky;
            top: 80px;
            display: flex;
            flex-direction: column;
        }

            .menu a {
                position: relative;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 12px;
                margin: 10px 0;
                color: white;
                text-decoration: none;
                border-radius: 12px;
                transition: .3s;
                overflow: hidden;
            }

                .menu a::before {
                    content: "";
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(90deg, rgba(37,99,235,0.25), rgba(147,51,234,0.25));
                    opacity: 0;
                    transition: .3s;
                }

                .menu a:hover::before {
                    opacity: 1;
                }

                .menu a:hover {
                    transform: translateX(8px);
                    box-shadow: 0 0 20px rgba(99, 102, 241, 0.25);
                    background: rgba(255, 255, 255, 0.06);
                }

            .menu a.active {
                background: linear-gradient(135deg, #2563eb, #9333ea);
                box-shadow: 0 0 15px rgba(37,99,235,.4), 0 0 25px rgba(147,51,234,.4);
                transform: translateX(6px);
            }

            /* MAIN SECTION */
        .main {
            flex: 1;
            padding: 30px;
            z-index: 2;
            display: flex;
            flex-direction: column;
        }

            /* FOOTER (Perfect Mirror Style) */
        .footer {
            width: 100%;
            text-align: center;
            padding: 15px;
            background: rgba(255, 255, 255, 0.04);
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            z-index: 10;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="header">
        <div class="logo">
            <i class="fa-solid fa-shield-halved"></i>
            CrimeVision Admin
        </div>
    </div>

    <div class="container">
        <div class="sidebar">
            <div class="menu">
                <a class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Admin"
                   asp-action="Dashboard">
                    <i class="fa-solid fa-gauge"></i> Dashboard
                </a>
                <a class="@(ViewContext.RouteData.Values["action"]?.ToString() == "CrimeReports" ? "active" : "")"
                   asp-controller="Admin"
                   asp-action="CrimeReports">
                    <i class="fa-solid fa-file"></i> Crime Reports
                </a>
                <a class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")"
                   asp-controller="Admin"
                   asp-action="Users">
                    <i class="fa-solid fa-users"></i> Users
                </a>
                <a class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Officers" ? "active" : "")"
                   asp-controller="Officers"
                   asp-action="Index">
                    <i class="fa-solid fa-users"></i> Officers
                </a>
                <a class="@(ViewContext.RouteData.Values["action"]?.ToString() == "AlertsList" ? "active" : "")"
                   asp-controller="Admin"
                   asp-action="AlertsList">
                    <i class="fa-solid fa-triangle-exclamation"></i> Broadcast Alert
                </a>

                <!-- === LOGOUT LINK === -->
                <a href="@Url.Action("AdminLogin", "Account")">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </div>

        <div class="main">
            @RenderBody()
        </div>
    </div>

    <div class="footer">
        © 2026 CrimeVision | Smart Crime Reporting & Tracking System
    </div>

    @await RenderSectionAsync("Scripts", required: false)</body>
</html>