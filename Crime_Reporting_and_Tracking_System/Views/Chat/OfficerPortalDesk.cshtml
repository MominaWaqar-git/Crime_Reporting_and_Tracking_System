@model IEnumerable<Crime_Reporting_and_Tracking_System.Models.ChatMessages>
@{
    Layout = null;
    string selectedCitizen = ViewBag.SelectedCitizenPhone;
    string officerPhone = ViewBag.OfficerPhone;
    string officerName = ViewBag.OfficerName;
    int? activeChatId = ViewBag.ActiveChatId;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Officer Portal - CrimeVision</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        :root {
            --emerald: #10b981;
            --cyber: #06b6d4;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            min-height: 100vh;
            background: #020617;
            color: white;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        .blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(130px);
            opacity: .4;
            z-index: 0;
        }

        .b1 {
            width: 500px;
            height: 500px;
            background: var(--emerald);
            top: -150px;
            left: -150px;
        }

        .b2 {
            width: 400px;
            height: 400px;
            background: var(--cyber);
            bottom: -100px;
            right: -100px;
        }

        .header {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 15px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            z-index: 10;
        }

        .logo {
            font-size: 20px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #34d399;
        }

        .badge-officer {
            background: rgba(16, 185, 129, 0.2);
            color: #34d399;
            border: 1px solid #10b981;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .chat-wrapper {
            flex: 1;
            margin-top: 85px;
            padding: 20px 5%;
            z-index: 2;
        }

        .main-chat-container {
            display: flex;
            height: 78vh;
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(15px);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .chat-sidebar {
            width: 320px;
            background: #0b0f19;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            flex-direction: column;
        }

        .sidebar-title {
            padding: 20px;
            font-size: 14px;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .chat-users-list {
            overflow-y: auto;
            flex: 1;
        }

        .user-item {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            gap: 12px;
            color: white;
            text-decoration: none;
            border-bottom: 1px solid rgba(255,255,255,0.02);
            transition: 0.2s;
        }

            .user-item:hover, .user-item.active-session {
                background: rgba(16, 185, 129, 0.1);
                border-left: 3px solid var(--emerald);
            }

        .avatar-placeholder {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #1e293b;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--emerald);
            font-weight: bold;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .chat-window {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: rgba(15, 23, 42, 0.2);
        }

        .chat-header {
            padding: 18px 20px;
            background: #0b0f19;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .chat-body-messages {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .message-bubble {
            max-width: 60%;
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 14px;
            line-height: 1.5;
        }

        .msg-right {
            align-self: flex-end;
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            border-bottom-right-radius: 2px;
        }

        .msg-left {
            align-self: flex-start;
            background: #1e293b;
            color: #f1f5f9;
            border-bottom-left-radius: 2px;
            border: 1px solid rgba(255,255,255,0.03);
        }

        .msg-system {
            align-self: center;
            background: rgba(14, 116, 144, 0.2);
            border: 1px dashed #06b6d4;
            color: #22d3ee;
            font-size: 12px;
            border-radius: 6px;
            text-align: center;
        }

        .msg-meta {
            font-size: 10px;
            opacity: 0.5;
            margin-top: 6px;
            text-align: right;
        }

        .msg-left .msg-meta {
            text-align: left;
        }

        .chat-image-attachment {
            max-width: 250px;
            max-height: 200px;
            border-radius: 8px;
            margin-top: 5px;
            cursor: pointer;
            border: 1px solid rgba(255,255,255,0.1);
            display: block;
        }

        .chat-footer {
            padding: 15px 20px;
            background: #0b0f19;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .input-wrapper {
            display: flex;
            gap: 12px;
        }

        .message-input {
            flex: 1;
            background: #0f172a;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            padding: 12px 16px;
            color: white;
            outline: none;
            transition: 0.2s;
        }

            .message-input:focus {
                border-color: var(--emerald);
            }

        .send-btn {
            background: var(--emerald);
            color: white;
            border: none;
            padding: 0 24px;
            border-radius: 8px;
            font-weight: 500;
            transition: 0.2s;
        }

            .send-btn:hover {
                background: #059669;
            }

        .system-footer {
            width: 100%;
            text-align: center;
            padding: 15px;
            background: rgba(15, 23, 42, 0.6);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            font-size: 12px;
            color: #64748b;
            margin-top: auto;
        }
    </style>
</head>
<body>

    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="header">
        <div class="logo"><i class="fa-solid fa-building-shield"></i> CrimeVision Field Intelligence Portal</div>

        <div class="d-flex gap-2">
            <a href="/Chat/OfficerPortalDesk?phone=@officerPhone&receiverType=Citizen" class="btn btn-sm @(ViewBag.ReceiverType == "Citizen" ? "btn-success" : "btn-outline-light")">
                <i class="fa-solid fa-users"></i> Citizen Hotline
            </a>
            <a href="/Chat/OfficerPortalDesk?phone=@officerPhone&receiverType=Admin" class="btn btn-sm @(ViewBag.ReceiverType == "Admin" ? "btn-warning text-dark" : "btn-outline-warning")">
                <i class="fa-solid fa-headset"></i> Connect Central Admin
            </a>
        </div>

        <div class="d-flex align-items-center gap-3">
            <span class="badge-officer"><i class="fa-solid fa-user-tie"></i> Officer: @officerName</span>
            <a href="/Home/Index" class="btn btn-sm btn-outline-secondary text-white border-secondary"><i class="fa-solid fa-power-off"></i> Logout</a>
        </div>
    </div>

    <div class="chat-wrapper">
        <div class="main-chat-container">

            <div class="chat-sidebar">
                <div class="sidebar-title"><i class="fa-solid fa-folder-tree me-2"></i> Active Assigned Cases</div>
                <div class="chat-users-list">
                    @if (ViewBag.ActiveCitizensForOfficer != null)
                    {
                        foreach (var target in ViewBag.ActiveCitizensForOfficer)
                        {
                            string sessionStatus = selectedCitizen == target.CitizenPhone ? "active-session" : "";
                            <a href="/Chat/OfficerChat?officerPhone=@officerPhone&citizenPhone=@target.CitizenPhone" class="user-item @sessionStatus">
                                <div class="avatar-placeholder">
                                    @(string.IsNullOrEmpty(target.CitizenName) ? "?" : target.CitizenName.Substring(0, 1).ToUpper())
                                </div>
                                <div style="flex: 1;">
                                    <div style="font-size: 14px; font-weight: 600; color: #f8fafc;">@target.CitizenName</div>
                                    <div style="font-size: 11px; color: #94a3b8; margin-top: 2px;"><i class="fa-solid fa-mobile-screen-button"></i> @target.CitizenPhone</div>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>

            <div class="chat-window">
                @if (!string.IsNullOrEmpty(selectedCitizen))
                {
                    <div class="chat-header">
                        <div style="font-size: 16px; font-weight: 600; color: #f8fafc;">
                            <i class="fa-solid fa-user-shield text-emerald me-2"></i> Interrogation & Statements Line
                            <span class="ms-3 text-muted" style="font-size: 12px; font-weight: 400;"><i class="fa-solid fa-link"></i> Target Phone: @selectedCitizen</span>
                        </div>
                    </div>

                    <div class="chat-body-messages" id="officerLogsBox">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var msg in Model)
                            {
                                string sideClass = "msg-left";
                                bool systemLine = string.Equals(msg.SenderType, "System", StringComparison.OrdinalIgnoreCase);

                                if (string.Equals(msg.SenderType, "Officer", StringComparison.OrdinalIgnoreCase)) { sideClass = "msg-right"; }
                                else if (systemLine) { sideClass = "msg-system"; }

                                <div class="message-bubble @sideClass">
                                    @if (!systemLine)
                                    {
                                        <div style="font-size: 11px; font-weight: 600; opacity: 0.8; margin-bottom: 3px;">@msg.SenderName</div>
                                    }

                                    <div>
                                        @* --- IMAGE CHECK AND RENDER INSIDE LOOP --- *@
                                        @if (systemLine && msg.MessageText != null)
                                        {
                                            @Html.Raw(msg.MessageText.Replace("*", "").Replace("\n", "<br/>"))
                                        }
                                        else if (msg.MessageText != null &&
                                        (msg.MessageText.ToLower().StartsWith("/uploads/") ||
                                        msg.MessageText.ToLower().StartsWith("http://") ||
                                        msg.MessageText.ToLower().StartsWith("https://")) &&
                                        (msg.MessageText.ToLower().EndsWith(".jpg") ||
                                        msg.MessageText.ToLower().EndsWith(".jpeg") ||
                                        msg.MessageText.ToLower().EndsWith(".png") ||
                                        msg.MessageText.ToLower().EndsWith(".gif")))
                                        {
                                            <img src="@msg.MessageText" class="chat-image-attachment" alt="Attachment" onclick="window.open(this.src)" />
                                        }
                                        else
                                        {
                                            @msg.MessageText
                                        }
                                    </div>
                                    <div class="msg-meta">@msg.Timestamp.ToString("hh:mm tt")</div>
                                </div>
                            }
                        }
                        else
                        {
                            <div id="noMessagesPlaceholder" style="margin: auto; text-align: center; color: #475569; font-size: 13px;">
                                <i class="fa-solid fa-message-slash d-block mb-2" style="font-size: 28px;"></i>
                                Verification successful. Channel completely encrypted. Say Hello!
                            </div>
                        }
                    </div>

                    <div class="chat-footer">
                        <form action="/Chat/SendOfficerMessage" method="post" id="officerSendForm" onsubmit="submitOfficerAJAX(event)">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="chatId" value="@activeChatId" />
                            <input type="hidden" name="officerPhone" value="@officerPhone" />
                            <input type="hidden" name="citizenPhone" value="@selectedCitizen" />
                            <input type="hidden" name="senderName" value="@officerName" />

                            <div class="input-wrapper">
                                <input type="text" name="messageText" id="officerInputText" class="message-input" placeholder="Type transmission log..." autocomplete="off" required />
                                <button type="submit" class="send-btn"><i class="fa-solid fa-paper-plane"></i> Send</button>
                            </div>
                        </form>
                    </div>
                }
                else
                {
                    <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; color:#475569;">
                        <i class="fa-solid fa-folder-lock" style="font-size: 70px; margin-bottom: 15px; color: #334155;"></i>
                        <h5>Secure Communications Vault</h5>
                        <p style="font-size: 12px; max-width: 350px; text-align: center;">Please select an active complaint profile from the desk pipeline sidebar grid matrix to connect.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="system-footer">© 2026 CrimeVision Matrix Protocol | End-to-End Cryptography Logged</div>

    <script>
        function scrollToBottom() {
            var container = document.getElementById("officerLogsBox");
            if(container) {
                container.scrollTop = container.scrollHeight;
            }
        }

        scrollToBottom();

        function submitOfficerAJAX(e) {
            e.preventDefault();
            var form = document.getElementById('officerSendForm');
            var txt = document.getElementById('officerInputText');
            if(!txt.value.trim()) return;

            var formData = new FormData(form);
            fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            }).then(res => {
                if(res.ok) {
                    txt.value = '';
                    fetchOfficerMessagesJSON();
                }
            }).catch(err => console.error("Error sending message:", err));
        }

        function fetchOfficerMessagesJSON() {
            var chatId = '@activeChatId';
            if(!chatId || chatId === '0' || chatId === '') return;

            fetch('/Chat/GetMessagesJson?chatId=' + chatId)
                .then(response => response.json())
                .then(messages => {
                    var container = document.getElementById('officerLogsBox');
                    if (!container) return;

                    if (messages.length === 0) {
                        container.innerHTML = `
                            <div id="noMessagesPlaceholder" style="margin: auto; text-align: center; color: #475569; font-size: 13px;">
                                <i class="fa-solid fa-message-slash d-block mb-2" style="font-size: 28px;"></i>
                                Verification successful. Channel completely encrypted. Say Hello!
                            </div>`;
                        return;
                    }

                    let finalHtml = "";
                    messages.forEach(msg => {
                        let sideClass = "msg-left";
                        let senderTypeLower = msg.senderType ? msg.senderType.toLowerCase() : '';
                        let systemLine = senderTypeLower === 'system';

                        if (senderTypeLower === 'officer') { sideClass = "msg-right"; }
                        else if (systemLine) { sideClass = "msg-system"; }

                        // JavaScript Image Parser Logic
                        let contentHtml = msg.messageText || '';
                        let textLower = contentHtml.toLowerCase();

                        if (!systemLine && contentHtml !== '' &&
                            (textLower.startsWith('/uploads/') || textLower.startsWith('http://') || textLower.startsWith('https://')) &&
                            (textLower.endsWith('.jpg') || textLower.endsWith('.jpeg') || textLower.endsWith('.png') || textLower.endsWith('.gif'))) {
                            contentHtml = `<img src="${msg.messageText}" class="chat-image-attachment" alt="Attachment" onclick="window.open(this.src)" />`;
                        } else if (systemLine && contentHtml !== '') {
                            contentHtml = contentHtml.replace(/\*/g, "").replace(/\n/g, "<br/>");
                        }

                        finalHtml += `
                            <div class="message-bubble ${sideClass}">
                                ${!systemLine ? `<div style="font-size: 11px; font-weight: 600; opacity: 0.8; margin-bottom: 3px;">${msg.senderName}</div>` : ""}
                                <div>${contentHtml}</div>
                                <div class="msg-meta">${msg.formattedTime || ''}</div>
                            </div>`;
                    });

                    if (container.innerHTML.trim() !== finalHtml.trim()) {
                        container.innerHTML = finalHtml;
                        scrollToBottom();
                    }
                })
                .catch(error => console.error("Error syncing transmission logs:", error));
        }

        @if (activeChatId.HasValue)
        {
                    <text>
                    setInterval(fetchOfficerMessagesJSON, 3000);
                    </text>
        }
    </script>
</body>
</html>