@model IEnumerable<Crime_Reporting_and_Tracking_System.Models.ChatMessages>
@{
    Layout = null;
    string selectedCitizen = ViewBag.SelectedCitizenPhone;
    string officerPhone = ViewBag.OfficerPhone;
    string officerName = ViewBag.OfficerName;
    int? activeChatId = ViewBag.ActiveChatId;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Officer Portal - CrimeVision</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
            :root {
                --blue: #2563eb;
                --purple: #9333ea;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            body {
                min-height: 100vh;
                background: #050816;
                color: white;
                display: flex;
                flex-direction: column;
                overflow-x: hidden;
            }

            .blob {
                position: fixed;
                border-radius: 50%;
                filter: blur(130px);
                opacity: .4;
                z-index: 0;
            }

            .b1 {
                width: 500px;
                height: 500px;
                background: var(--blue);
                top: -150px;
                left: -150px;
            }

            .b2 {
                width: 400px;
                height: 400px;
                background: var(--purple);
                bottom: -100px;
                right: -100px;
            }

            .header {
                position: fixed;
                top: 0;
                width: 100%;
                padding: 15px 5%;
                display: flex;
                justify-content: space-between;
                align-items: center;
                background: rgba(255, 255, 255, 0.05);
                backdrop-filter: blur(15px);
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                z-index: 10;
            }

            .logo {
                font-size: 20px;
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 10px;
                color: #fff;
            }

            .badge-officer {
                background: rgba(255, 255, 255, 0.06);
                color: #a29bfe;
                border: 1px solid rgba(255, 255, 255, 0.1);
                padding: 4px 10px;
                border-radius: 20px;
                font-size: 12px;
                font-weight: 500;
            }

            .chat-wrapper {
                flex: 1;
                margin-top: 85px;
                padding: 20px 5%;
                z-index: 2;
            }

            .main-chat-container {
                display: flex;
                height: 78vh;
                background: rgba(24, 21, 44, 0.6);
                backdrop-filter: blur(15px);
                border-radius: 16px;
                overflow: hidden;
                border: 1px solid rgba(255, 255, 255, 0.08);
            }

            .chat-sidebar {
                width: 320px;
                background: rgba(13, 11, 26, 0.9);
                border-right: 1px solid rgba(255, 255, 255, 0.08);
                display: flex;
                flex-direction: column;
            }

            .sidebar-title {
                padding: 20px;
                font-size: 14px;
                font-weight: 600;
                color: #a29bfe;
                text-transform: uppercase;
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            }

            .user-item {
                display: flex;
                align-items: center;
                padding: 15px 20px;
                gap: 12px;
                color: white;
                text-decoration: none;
                border-bottom: 1px solid rgba(255,255,255,0.02);
            }

                .user-item:hover, .user-item.active-session {
                    background: rgba(255, 255, 255, 0.06);
                    border-left: 3px solid var(--purple);
                }

            .avatar-placeholder {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                background: #1e293b;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--purple);
                font-weight: bold;
            }

            .chat-window {
                flex: 1;
                display: flex;
                flex-direction: column;
                background: transparent;
            }

            .chat-header {
                padding: 18px 20px;
                background: rgba(255, 255, 255, 0.03);
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            }

            .chat-body-messages {
                flex: 1;
                padding: 20px;
                overflow-y: auto;
                display: flex;
                flex-direction: column;
                gap: 15px;
            }

            .message-bubble {
                max-width: 60%;
                padding: 12px 16px;
                border-radius: 12px;
                font-size: 14px;
            }

            .msg-right {
                align-self: flex-end;
                background: linear-gradient(135deg, #6c5ce7, #8e7cfc);
                color: white;
            }

            .msg-left {
                align-self: flex-start;
                background: rgba(255, 255, 255, 0.06);
                color: #f1f5f9;
            }

            /* Updated System Message Color */
            .msg-system {
                align-self: center;
                background: rgba(37, 99, 235, 0.15);
                border: 1px solid rgba(37, 99, 235, 0.3);
                color: #60a5fa;
                font-size: 12px;
                padding: 8px 12px;
                border-radius: 6px;
            }

            .msg-meta {
                font-size: 10px;
                opacity: 0.5;
                margin-top: 6px;
                text-align: right;
            }

            .msg-left .msg-meta {
                text-align: left;
            }

            .chat-footer {
                padding: 15px 20px;
                background: rgba(255, 255, 255, 0.02);
                border-top: 1px solid rgba(255, 255, 255, 0.05);
            }

            .message-input {
                flex: 1;
                background: rgba(0,0,0,0.2);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 8px;
                padding: 12px 16px;
                color: white;
                outline: none;
            }

            .send-btn {
                background: var(--purple);
                color: white;
                border: none;
                padding: 0 24px;
                border-radius: 8px;
            }

            /* Original Footer Design */
            .footer {
                padding: 15px;
                text-align: center;
                background: rgba(255,255,255,0.03);
                border-top: 1px solid rgba(255,255,255,0.05);
                margin-top: auto;
                color: #64748b;
                font-size: 12px;
            }
    </style>
</head>
<body>

    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="header">
        <div class="logo"><i class="fa-solid fa-building-shield"></i> CrimeVision Field Intelligence Portal</div>

        <div class="d-flex gap-2">
            <a href="/Chat/OfficerPortalDesk?phone=@officerPhone&receiverType=Citizen" class="btn btn-sm @(ViewBag.ReceiverType == "Citizen" ? "btn-primary" : "btn-outline-light")">
                <i class="fa-solid fa-users"></i> Citizen Hotline
            </a>
            <a href="/Chat/OfficerPortalDesk?phone=@officerPhone&receiverType=Admin" class="btn btn-sm @(ViewBag.ReceiverType == "Admin" ? "btn-warning text-dark" : "btn-outline-warning")">
                <i class="fa-solid fa-headset"></i> Connect Central Admin
            </a>
        </div>

        <div class="d-flex align-items-center gap-3">
            <span class="badge-officer"><i class="fa-solid fa-user-tie"></i> Officer: @officerName</span>
            <a href="/Home/Index" class="btn btn-sm btn-outline-secondary text-white border-secondary"><i class="fa-solid fa-power-off"></i> Logout</a>
        </div>
    </div>

    <div class="chat-wrapper">
        <div class="main-chat-container">
            <div class="chat-sidebar">
                <div class="sidebar-title"><i class="fa-solid fa-folder-tree me-2"></i> Active Assigned Cases</div>
                <div class="chat-users-list">
                    @if (ViewBag.ActiveCitizensForOfficer != null)
                    {
                        foreach (var target in ViewBag.ActiveCitizensForOfficer)
                        {
                            string sessionStatus = selectedCitizen == target.CitizenPhone ? "active-session" : "";
                            <a href="/Chat/GoToOfficerChat?officerPhone=@officerPhone&citizenPhone=@target.CitizenPhone&receiverType=Citizen"
                               class="user-item @(selectedCitizen == target.CitizenPhone ? "active-session" : "")">

                                <div class="avatar-placeholder">
                                    @(string.IsNullOrEmpty(target.CitizenName) ? "?" : target.CitizenName.Substring(0, 1).ToUpper())
                                </div>

                                <div style="display: flex; flex-direction: column; justify-content: center; gap: 2px;">
                                    <div style="font-size: 14px; font-weight: 600; color: #f8fafc;">
                                        @target.CitizenName
                                    </div>
                                    <div style="font-size: 11px; color: #94a3b8;">
                                        <i class="fa-solid fa-mobile-screen-button"></i> @target.CitizenPhone
                                    </div>
                                </div>
                            </a>
                           
                        }
                    }
                </div>
            </div>

            <div class="chat-window">
                @if (!string.IsNullOrEmpty(selectedCitizen))
                {
                    <div class="chat-header">
                        <div style="font-size: 16px; font-weight: 600; color: #f8fafc;">
                            <i class="fa-solid fa-user-shield text-purple me-2"></i> Interrogation & Statements Line
                            <span class="ms-3 text-muted" style="font-size: 12px; font-weight: 400;"><i class="fa-solid fa-link"></i> Target Phone: @selectedCitizen</span>
                        </div>
                    </div>

                    <div class="chat-body-messages" id="officerLogsBox">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var msg in Model)
                            {
                                string sideClass = "msg-left";
                                bool systemLine = string.Equals(msg.SenderType, "System", StringComparison.OrdinalIgnoreCase);
                                if (string.Equals(msg.SenderType, "Officer", StringComparison.OrdinalIgnoreCase)) { sideClass = "msg-right"; }
                                else if (systemLine) { sideClass = "msg-system"; }

                                <div class="message-bubble @sideClass">
                                    @if (!systemLine)
                                    {
                                        <div style="font-size: 11px; font-weight: 600; opacity: 0.8; margin-bottom: 3px;">@msg.SenderName</div>
                                    }
                                    <div>
                                        @if (systemLine && msg.MessageText != null)
                                        {
                                            @Html.Raw(msg.MessageText.Replace("*", "").Replace("\n", "<br/>"))
                                        }
                                        else if (msg.MessageText != null && (msg.MessageText.ToLower().StartsWith("/uploads/") || msg.MessageText.ToLower().Contains("http")) && (msg.MessageText.ToLower().EndsWith(".jpg") || msg.MessageText.ToLower().EndsWith(".png")))
                                        {

                                            <img src="@msg.MessageText" class="chat-image-attachment" alt="Attachment" onclick="window.open(this.src)" style="max-width:100%; border-radius:8px;" />
                                        }
                                        else
                                        {

                                            @msg.MessageText
                                        }
                                    </div>
                                    <div class="msg-meta">@msg.Timestamp.ToString("hh:mm tt")</div>
                                </div>
                            }
                        }
                        else
                        {
                            <div id="noMessagesPlaceholder" style="margin: auto; text-align: center; color: #475569; font-size: 13px;">
                                <i class="fa-solid fa-message-slash d-block mb-2" style="font-size: 28px;"></i>
                                Verification successful. Channel completely encrypted.
                            </div>
                        }
                    </div>

                    <div class="chat-footer">
                        <form action="/Chat/SendOfficerMessage" method="post" id="officerSendForm" onsubmit="submitOfficerAJAX(event)">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="chatId" value="@activeChatId" />
                            <input type="hidden" name="officerPhone" value="@officerPhone" />
                            <input type="hidden" name="citizenPhone" value="@selectedCitizen" />
                            <input type="hidden" name="senderName" value="@officerName" />
                            <div class="input-wrapper" style="display:flex; gap:12px;">
                                <input type="text" name="messageText" id="officerInputText" class="message-input" placeholder="Type transmission log..." autocomplete="off" required />
                                <button type="submit" class="send-btn"><i class="fa-solid fa-paper-plane"></i> Send</button>
                            </div>
                        </form>
                    </div>
                }
                else
                {
                    <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; color:#475569;">
                        <i class="fa-solid fa-folder-lock" style="font-size: 70px; margin-bottom: 15px; color: #334155;"></i>
                        <h5>Secure Communications Vault</h5>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="footer">© 2026 CrimeVision | Smart Crime Reporting & Tracking System</div>

    <script>
            function scrollToBottom() {
                var container = document.getElementById("officerLogsBox");
                if(container) container.scrollTop = container.scrollHeight;
            }
            scrollToBottom();

            function submitOfficerAJAX(e) {
                e.preventDefault();
                var form = document.getElementById('officerSendForm');
                var txt = document.getElementById('officerInputText');
                if(!txt.value.trim()) return;
                var formData = new FormData(form);
                fetch(form.action, { method: 'POST', body: formData, headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value } })
                .then(res => { if(res.ok) { txt.value = ''; fetchOfficerMessagesJSON(); } });
            }

            function fetchOfficerMessagesJSON() {
                var chatId = '@activeChatId';
                if(!chatId || chatId === '0') return;
                fetch('/Chat/GetMessagesJson?chatId=' + chatId)
                    .then(response => response.json())
                    .then(messages => {
                        var container = document.getElementById('officerLogsBox');
                        if (!container) return;
                        let finalHtml = "";
                        messages.forEach(msg => {
                            let senderTypeLower = msg.senderType ? msg.senderType.toLowerCase() : '';
                            let systemLine = senderTypeLower === 'system';
                            let sideClass = senderTypeLower === 'officer' ? "msg-right" : (systemLine ? "msg-system" : "msg-left");
                            let contentHtml = msg.messageText || '';

                            if (systemLine) { contentHtml = contentHtml.replace(/\*/g, "").replace(/\n/g, "<br/>"); }
                            else if ((contentHtml.startsWith('/uploads/') || contentHtml.includes('http')) && (contentHtml.endsWith('.jpg') || contentHtml.endsWith('.png'))) {
                                contentHtml = `<img src="${msg.messageText}" class="chat-image-attachment" alt="Attachment" onclick="window.open(this.src)" style="max-width:100%; border-radius:8px;" />`;
                            }

                            finalHtml += `<div class="message-bubble ${sideClass}">${!systemLine ? `<div style="font-size: 11px; font-weight: 600; opacity: 0.8; margin-bottom: 3px;">${msg.senderName}</div>` : ""}<div>${contentHtml}</div><div class="msg-meta">${msg.formattedTime || ''}</div></div>`;
                        });
                        if (container.innerHTML.trim() !== finalHtml.trim()) { container.innerHTML = finalHtml; scrollToBottom(); }
                    });
            }
            @if (activeChatId.HasValue)
            {
                <text>setInterval(fetchOfficerMessagesJSON, 3000);</text>
            }
    </script>
</body>
</html>