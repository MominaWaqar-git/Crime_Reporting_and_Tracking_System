@model IEnumerable<Crime_Reporting_and_Tracking_System.Models.ChatMessages>
@{
    Layout = null;
    string citizenPhone = ViewBag.CitizenPhone;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Secure HQ Desk - CrimeVision</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        :root {
            --blue: #1e3a8a;
            --cyan: #06b6d4;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            min-height: 100vh;
            background: #030712;
            color: white;
            display: flex;
            flex-direction: column;
        }

        .blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(130px);
            opacity: 0.4;
            z-index: 0;
        }

        .b1 {
            width: 400px;
            height: 400px;
            background: var(--blue);
            top: -50px;
            left: -50px;
        }

        .b2 {
            width: 400px;
            height: 400px;
            background: var(--cyan);
            bottom: -50px;
            right: -50px;
        }

        .header {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 15px 8%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(31, 41, 55, 0.4);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            z-index: 10;
        }

        .logo {
            font-size: 20px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .logo i {
                color: #22d3ee;
            }

        .back-dashboard {
            background: rgba(255,255,255,0.05);
            color: #9ca3af;
            border: 1px solid rgba(255,255,255,0.1);
            padding: 8px 16px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 13px;
            transition: 0.3s;
        }

            .back-dashboard:hover {
                background: #fff;
                color: #000;
            }

        .container-box {
            flex: 1;
            margin-top: 90px;
            padding: 10px 8% 30px 8%;
            z-index: 2;
            display: flex;
            justify-content: center;
        }

        .chat-panel {
            width: 100%;
            max-width: 900px;
            height: 75vh;
            background: rgba(17, 24, 39, 0.7);
            backdrop-filter: blur(20px);
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.08);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .panel-header {
            padding: 15px 20px;
            background: rgba(31, 41, 55, 0.8);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .badge-online {
            width: 10px;
            height: 10px;
            background: #10b981;
            border-radius: 50%;
            box-shadow: 0 0 8px #10b981;
        }

        .chat-body {
            flex: 1;
            padding: 25px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
            background: rgba(10, 15, 30, 0.3);
        }

        .bubble {
            max-width: 65%;
            padding: 12px 16px;
            border-radius: 14px;
            font-size: 14px;
            line-height: 1.5;
        }

        /* Citizen Specific Bubble Alignments */
        .bubble-citizen {
            align-self: flex-end;
            background: linear-gradient(135deg, #06b6d4, #0891b2);
            color: white;
            border-bottom-right-radius: 2px;
        }

        .bubble-admin {
            align-self: flex-start;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.05);
            border-bottom-left-radius: 2px;
        }

        .bubble-sys {
            align-self: center;
            background: rgba(245, 158, 11, 0.1);
            border: 1px dashed rgba(245, 158, 11, 0.5);
            color: #f59e0b;
            font-size: 12px;
            text-align: center;
        }

        .time-label {
            font-size: 10px;
            opacity: 0.5;
            display: block;
            margin-top: 5px;
            text-align: right;
        }

        .bubble-admin .time-label {
            text-align: left;
        }

        .panel-footer {
            padding: 15px 20px;
            background: rgba(17, 24, 39, 0.9);
            border-top: 1px solid rgba(255,255,255,0.08);
        }

        .input-bar {
            display: flex;
            gap: 12px;
        }

        .client-input {
            flex: 1;
            background: #0b0f19;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            padding: 12px 15px;
            color: white;
            outline: none;
            font-size: 14px;
        }

            .client-input:focus {
                border-color: #06b6d4;
            }

        .btn-send {
            background: #06b6d4;
            color: white;
            border: none;
            padding: 0 25px;
            border-radius: 10px;
            font-weight: 500;
            transition: 0.3s;
        }

            .btn-send:hover {
                background: #0891b2;
                box-shadow: 0 0 15px rgba(6, 182, 212, 0.4);
            }

        .footer-text {
            width: 100%;
            text-align: center;
            padding: 15px;
            background: rgba(255, 255, 255, 0.02);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            font-size: 12px;
            opacity: 0.5;
            margin-top: auto;
        }
    </style>
</head>
<body>

    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="header">
        <div class="logo"><i class="fa-solid fa-user-shield"></i> CrimeVision Citizen Node</div>

        <!-- 🔥 FIXED: MVC Tag Helper Link mapped properly for Citizen Dashboard -->
        <a asp-action="Dashboard" asp-controller="Citizen" class="back-dashboard">
            <i class="fa-solid fa-table-columns"></i> Dashboard
        </a>
    </div>

    <div class="container-box">
        <div class="chat-panel">
            <div class="panel-header">
                <div class="badge-online"></div>
                <div>
                    <h6 class="m-0 font-weight-bold">Command Center Desk</h6>
                    <small class="text-muted" style="font-size: 11px;">Encrypted connection</small>
                </div>
            </div>

            <div class="chat-body" id="citizenLogs">
                @if (Model != null && Model.Any())
                {
                    foreach (var msg in Model)
                    {
                        if (msg.SenderType == "System")
                        {
                            <div class="bubble bubble-sys">@msg.MessageText</div>
                        }
                        else
                        {
                            string clientClass = (msg.SenderType == "Admin") ? "bubble-admin" : "bubble-citizen";
                            <div class="bubble @clientClass">
                                <span style="font-size:11px; font-weight:600; opacity:0.8; display:block; margin-bottom:2px;">@msg.SenderName</span>
                                <div>@msg.MessageText</div>
                                <span class="time-label">@msg.Timestamp.ToString("hh:mm tt")</span>
                            </div>
                        }
                    }
                }
                else
                {
                    <div style="margin:auto; text-align:center; opacity:0.3;">
                        <i class="fa-solid fa-shield-halved" style="font-size: 50px; margin-bottom: 10px;"></i>
                        <p>No transmissions logged yet. Type below to ping desk officer.</p>
                    </div>
                }
            </div>

            <div class="panel-footer">
                <!-- 🔥 OPTIMIZED: Handled route directly mapping forms cleanly -->
                <form asp-action="SendCitizenMessage" asp-controller="Chat" method="post" class="input-bar">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="chatId" value="@ViewBag.ActiveChatId" />
                    <input type="hidden" name="citizenPhone" value="@citizenPhone" />

                    <input type="text" name="messageText" class="client-input" placeholder="Type your secure message here..." required autocomplete="off" />
                    <button type="submit" class="btn-send"><i class="fa-solid fa-paper-plane"></i> Send</button>
                </form>
            </div>
        </div>
    </div>

    <div class="footer-text">Protected by federal criminal tracking infrastructure system © 2026</div>

    <script>
        window.addEventListener('DOMContentLoaded', (event) => {
            var logBox = document.getElementById("citizenLogs");
            if(logBox) {
                logBox.scrollTop = logBox.scrollHeight;
            }
        });
    </script>
</body>
</html>