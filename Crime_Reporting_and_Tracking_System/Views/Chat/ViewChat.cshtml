@model IEnumerable<Crime_Reporting_and_Tracking_System.Models.ChatMessages>
@{
    Layout = null;
    string currentCitizenPhone = ViewBag.SelectedCitizenPhone;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Investigation Room - CrimeVision</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        :root {
            --blue: #2563eb;
            --purple: #9333ea;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            min-height: 100vh;
            background: #050816;
            color: white;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
        }

        .blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(120px);
            opacity: .6;
            z-index: 0;
        }

        .b1 {
            width: 450px;
            height: 450px;
            background: var(--blue);
            top: -120px;
            left: -120px;
        }

        .b2 {
            width: 450px;
            height: 450px;
            background: var(--purple);
            bottom: -120px;
            right: -120px;
        }

        .header {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 15px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 10;
        }

        .logo {
            font-size: 22px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .logo i {
                color: #60a5fa;
            }

        .exit-btn {
            background: linear-gradient(135deg, #ef4444, #b91c1c);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 500;
            font-size: 14px;
            transition: 0.3s;
            box-shadow: 0 0 15px rgba(239, 68, 68, 0.3);
        }

            .exit-btn:hover {
                transform: translateY(-2px);
                color: white;
            }

        .chat-wrapper {
            flex: 1;
            margin-top: 85px;
            padding: 20px 5%;
            z-index: 2;
        }

        .main-chat-container {
            display: flex;
            height: 78vh;
            background: rgba(24, 21, 44, 0.6);
            backdrop-filter: blur(15px);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .chat-sidebar {
            width: 340px;
            background: rgba(13, 11, 26, 0.9);
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 20px 20px 10px 20px;
            font-size: 16px;
            font-weight: 600;
            color: #a29bfe;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .search-box-container {
            padding: 0 20px 15px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .sidebar-search {
            width: 100%;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 8px 12px 8px 35px;
            color: white;
            font-size: 13px;
            outline: none;
            transition: 0.3s;
        }

            .sidebar-search:focus {
                border-color: #6c5ce7;
                box-shadow: 0 0 10px rgba(108, 92, 231, 0.3);
            }

        .search-icon-wrapper {
            position: relative;
        }

            .search-icon-wrapper i {
                position: absolute;
                left: 12px;
                top: 12px;
                color: rgba(255,255,255,0.4);
                font-size: 13px;
            }

        .add-chat-icon-btn {
            background: rgba(108, 92, 231, 0.2);
            color: #a29bfe;
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }

            .add-chat-icon-btn:hover {
                background: #6c5ce7;
                color: white;
            }

        .chat-users-list {
            overflow-y: auto;
            flex: 1;
        }

        .user-item {
            display: flex;
            align-items: center;
            padding: 15px;
            gap: 12px;
            color: white;
            text-decoration: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }

            .user-item:hover, .user-item.active-session {
                background: rgba(108, 92, 231, 0.15);
            }

        .avatar-image {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid #6c5ce7;
            background: #1e1a3a;
        }

        .chat-window {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: rgba(21, 18, 41, 0.4);
        }

        .chat-header {
            padding: 15px 20px;
            background: rgba(24, 21, 44, 0.9);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .chat-body-messages {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .message-bubble {
            max-width: 60%;
            padding: 10px 14px;
            border-radius: 12px;
            color: white;
            font-size: 14px;
            position: relative;
        }

        .msg-right {
            align-self: flex-end;
            background: linear-gradient(135deg, #6c5ce7, #8e7cfc);
            border-bottom-right-radius: 2px;
        }

        .msg-left {
            align-self: flex-start;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-bottom-left-radius: 2px;
        }

        .msg-system {
            align-self: center;
            background: rgba(241, 196, 15, 0.15);
            border: 1px dashed #f1c40f;
            color: #f1c40f;
            text-align: center;
            font-size: 12px;
        }

        .delete-btn {
            background: none;
            border: none;
            color: #ff7675;
            cursor: pointer;
            font-size: 11px;
            opacity: 0;
            transition: opacity 0.2s;
            padding: 0;
            margin-left: 8px;
        }

        .message-bubble:hover .delete-btn {
            opacity: 1;
        }

        .msg-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 10px;
            opacity: 0.6;
            margin-top: 5px;
        }

        .chat-footer {
            padding: 15px 20px;
            background: rgba(24, 21, 44, 0.9);
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .input-group-custom {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .message-input {
            flex: 1;
            background: #131026;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            padding: 12px;
            color: white;
            outline: none;
        }

        .attach-btn {
            background: rgba(255, 255, 255, 0.05);
            color: #a29bfe;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            cursor: pointer;
        }

            .attach-btn:hover {
                background: rgba(108, 92, 231, 0.2);
                color: white;
            }

            .attach-btn.has-file {
                background: #2ed573 !important;
                color: white !important;
                border-color: #2ed573;
            }

        .chat-image-attachment {
            max-width: 100%;
            max-height: 200px;
            border-radius: 8px;
            margin-top: 5px;
            cursor: pointer;
            transition: transform 0.2s;
        }

            .chat-image-attachment:hover {
                transform: scale(1.02);
            }

        .send-btn {
            background: #6c5ce7;
            color: white;
            border: none;
            padding: 0 20px;
            height: 45px;
            border-radius: 8px;
        }

        .dark-modal {
            background-color: #131026 !important;
            color: white !important;
            border: 1px solid #6c5ce7;
        }

            .dark-modal input, .dark-modal select {
                background-color: #0d0b1a !important;
                border: 1px solid rgba(255,255,255,0.1) !important;
                color: white !important;
            }

        .system-footer {
            width: 100%;
            text-align: center;
            padding: 15px;
            background: rgba(255, 255, 255, 0.04);
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            font-size: 13px;
            margin-top: auto;
        }
    </style>
</head>
<body>

    @Html.AntiForgeryToken()
    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="header">
        <div class="logo"><i class="fa-solid fa-shield-halved"></i> CrimeVision Secure Communications</div>
        <a href="/Admin/CrimeReports" class="exit-btn"><i class="fa-solid fa-arrow-left-long"></i> Exit Console</a>
    </div>

    <div class="chat-wrapper">
        <div class="main-chat-container">

            <div class="chat-sidebar">
                <div class="sidebar-header">
                    <span><i class="fa-solid fa-comments"></i> Case Rooms</span>
                    <button class="add-chat-icon-btn" data-bs-toggle="modal" data-bs-target="#newChatModal">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                </div>

                <div class="search-box-container">
                    <div class="search-icon-wrapper">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" id="sidebarSearchInput" class="sidebar-search" placeholder="Search by Name or Phone..." onkeyup="filterSidebarChats()" />
                    </div>
                </div>

                <div class="chat-users-list" id="chatUsersList">
                    @if (ViewBag.ChatList != null)
                    {
                        foreach (var chat in ViewBag.ChatList)
                        {
                            string activeClass = currentCitizenPhone == chat.CitizenPhone ? "active-session" : "";

                            <a href="/Chat/ViewChat?citizenPhone=@chat.CitizenPhone" class="user-item @activeClass">
                                <img src="@chat.ProfileImage" class="avatar-image" alt="Avatar" />
                                <div style="flex:1;">
                                    <div class="chat-name" style="font-weight:bold; font-size:14px; color:#fff;">@chat.CitizenName</div>
                                    <div class="chat-phone" style="font-size:12px; color:#a29bfe; margin-top:2px;"><i class="fa-solid fa-phone"></i> @chat.CitizenPhone</div>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>

            <div class="chat-window">
                @if (!string.IsNullOrEmpty(currentCitizenPhone))
                {
                    <div class="chat-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong style="font-size: 16px;">@ViewBag.SelectedCitizenName</strong>
                                <span class="ms-3 text-muted" style="font-size:13px;"><i class="fa-solid fa-phone"></i> @ViewBag.SelectedCitizenPhoneInfo</span>
                            </div>
                            <button class="btn btn-sm btn-outline-danger" onclick="confirmDeleteChat('@ViewBag.ActiveChatId', '@currentCitizenPhone')">
                                <i class="fa-solid fa-dumpster-fire"></i> Delete Room
                            </button>
                        </div>
                    </div>

                    <div class="chat-body-messages" id="chatLogsContainer">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var msg in Model)
                            {
                                string bubbleSide = "msg-left";
                                bool isSystem = string.Equals(msg.SenderType, "System", StringComparison.OrdinalIgnoreCase);

                                if (string.Equals(msg.SenderType, "Admin", StringComparison.OrdinalIgnoreCase)) { bubbleSide = "msg-right"; }
                                else if (isSystem) { bubbleSide = "msg-system"; }

                                <div class="message-bubble @bubbleSide">
                                    @if (!isSystem)
                                    {
                                        <div style="font-size: 11px; font-weight: bold; opacity: 0.8; margin-bottom: 4px;">
                                            @msg.SenderName <span style="font-weight: 300; opacity: 0.7;">(@msg.SenderType)</span>
                                        </div>
                                    }

                                    <div class="msg-content-text">
                                        @if (isSystem && msg.MessageText != null)
                                        {
                                            @Html.Raw(msg.MessageText.Replace("*", "").Replace("\n", "<br/>"))
                                        }
                                        else if (msg.MessageText != null)
                                        {
                                            // 🔥 FIXED FOR RAZOR COMPILER: Casing handling for (.PNG, .JPG etc) inside C# block
                                            var textLower = msg.MessageText.Trim().ToLower();
                                            var isImgPath = (textLower.StartsWith("/uploads/") || textLower.StartsWith("http://") || textLower.StartsWith("https://")) &&
                                            (textLower.EndsWith(".jpg") || textLower.EndsWith(".jpeg") || textLower.EndsWith(".png") || textLower.EndsWith(".gif"));

                                            if (isImgPath)
                                            {
                                                <img src="@msg.MessageText" class="chat-image-attachment" alt="Transmission Attachment" onclick="zoomImage(this.src)" />
                                            }
                                            else
                                            {
                                                @msg.MessageText
                                            }
                                        }
                                    </div>

                                    <div class="msg-footer">
                                        <span>@msg.Timestamp.ToString("hh:mm tt")</span>
                                        @if (string.Equals(msg.SenderType, "Admin", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <form action="/Chat/DeleteMessage" method="post" style="display:inline;" onsubmit="deleteMessageAJAX(event, this)">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="messageId" value="@msg.MessageId" />
                                                <input type="hidden" name="citizenPhone" value="@currentCitizenPhone" />
                                                <button type="submit" class="delete-btn"><i class="fa-solid fa-trash-can"></i> Unsend</button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div id="noMessagesPlaceholder" style="text-align: center; color: rgba(255,255,255,0.3); margin: auto 0; font-size: 13px;">
                                <i class="fa-solid fa-folder-open d-block mb-2" style="font-size: 30px;"></i>
                                No transmission logs found in this secure room.
                            </div>
                        }
                    </div>

                    <div class="chat-footer">
                        <form action="/Chat/SendMessage" method="post" class="input-group-custom" id="sendMessageForm" enctype="multipart/form-data" onsubmit="submitMessageAJAX(event)">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="chatId" value="@ViewBag.ActiveChatId" />
                            <input type="hidden" name="citizenPhone" value="@currentCitizenPhone" />
                            <input type="hidden" name="senderType" value="Admin" />
                            <input type="hidden" name="senderName" value="Head Desk Officer" />

                            <input type="file" name="imageFile" id="imageFileInput" accept="image/*" style="display:none;" onchange="handleFileSelect()" />
                            <button type="button" class="attach-btn" id="attachBtn" onclick="document.getElementById('imageFileInput').click();" title="Attach Evidence Image">
                                <i class="fa-solid fa-paperclip"></i>
                            </button>

                            <input type="text" name="messageText" id="messageTextInput" class="message-input" placeholder="Type transmission message..." autocomplete="off" />
                            <button type="submit" class="send-btn btn btn-primary"><i class="fa-solid fa-paper-plane"></i> Send</button>
                        </form>
                    </div>
                }
                else
                {
                    <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; color:rgba(255,255,255,0.2);">
                        <i class="fa-solid fa-comments" style="font-size: 80px; margin-bottom: 15px;"></i>
                        <h4>Centralized Communication Portal</h4>
                        <p style="font-size: 13px;">Select an existing secure room or use the "+" icon to establish a new channel connection.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="modal fade" id="newChatModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content dark-modal">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa-solid fa-user-plus text-primary"></i> Initiate New Communication</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/Chat/CreateNewChat" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Target Connection Type</label>
                            <select name="isOfficer" class="form-select" required>
                                <option value="false" selected>Citizen / Witness / Victim (Awaam)</option>
                                <option value="true">Police Officer / Investigator (Staff)</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" name="personName" class="form-control" placeholder="Enter Full Name" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phone Number</label>
                            <input type="text" name="personPhone" class="form-control" placeholder="E.g., 03001234567" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" style="background:#6c5ce7; border:none;">Establish Connection</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="system-footer">© 2026 CrimeVision | Smart Crime Reporting & Tracking System</div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function scrollToBottom(force = false) {
            var objDiv = document.getElementById("chatLogsContainer");
            if (objDiv) {
                var isScrolledToBottom = objDiv.scrollHeight - objDiv.clientHeight <= objDiv.scrollTop + 100;
                if (isScrolledToBottom || force) {
                    objDiv.scrollTop = objDiv.scrollHeight;
                }
            }
        }

        // Run on load
        scrollToBottom(true);

        function filterSidebarChats() {
            var input = document.getElementById("sidebarSearchInput").value.toLowerCase();
            var items = document.querySelectorAll("#chatUsersList .user-item");

            items.forEach(function(item) {
                var name = item.querySelector(".chat-name").textContent.toLowerCase();
                var phone = item.querySelector(".chat-phone").textContent.toLowerCase();

                if (name.includes(input) || phone.includes(input)) {
                    item.style.setProperty("display", "flex", "important");
                } else {
                    item.style.setProperty("display", "none", "important");
                }
            });
        }

        const chatContainer = document.getElementById("chatLogsContainer");
        if (chatContainer) {
            const observer = new MutationObserver(() => {
                chatContainer.scrollTop = chatContainer.scrollHeight;
            });
            observer.observe(chatContainer, { childList: true });
        }

        // File Select UI feedback handles
        function handleFileSelect() {
            var fileInput = document.getElementById('imageFileInput');
            var attachBtn = document.getElementById('attachBtn');
            if (fileInput.files.length > 0) {
                attachBtn.classList.add('has-file');
                attachBtn.innerHTML = `<i class="fa-solid fa-check"></i>`;
                document.getElementById('messageTextInput').placeholder = "Image attached: " + fileInput.files[0].name;
            } else {
                attachBtn.classList.remove('has-file');
                attachBtn.innerHTML = `<i class="fa-solid fa-paperclip"></i>`;
                document.getElementById('messageTextInput').placeholder = "Type transmission message...";
            }
        }

        // Send Message AJAX
        function submitMessageAJAX(e) {
            e.preventDefault();
            var form = document.getElementById('sendMessageForm');
            var inputField = document.getElementById('messageTextInput');
            var fileInput = document.getElementById('imageFileInput');

            if (!inputField.value.trim() && fileInput.files.length === 0) return;

            var formData = new FormData(form);

            fetch(form.action, {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    inputField.value = '';
                    fileInput.value = '';
                    handleFileSelect();

                    // 500ms delay to give the server upload breathing room
                    setTimeout(function() {
                        triggerBackgroundRefresh();
                    }, 500);
                } else {
                    console.error("Server side par koi error aya hai.");
                }
            })
            .catch(error => console.error("Error sending message:", error));
        }

        // Delete Message AJAX
        function deleteMessageAJAX(e, form) {
            e.preventDefault();
            var formData = new FormData(form);
            fetch(form.action, {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if(response.ok) {
                    triggerBackgroundRefresh();
                }
            })
            .catch(error => console.error("Error deleting message:", error));
        }

        // 🔥 UPGRADED AJAX AUTO REFRESH HANDLER: Handles both Partial View & Raw Text safely
        function triggerBackgroundRefresh() {
            var citizenPhone = '@currentCitizenPhone';
            if(!citizenPhone) return;

            fetch('/Chat/GetMessagesPartial?citizenPhone=' + citizenPhone)
                .then(response => {
                    if (!response.ok) throw new Error("Partial View not found");
                    return response.text();
                })
                .then(htmlContent => {
                    var currentContainer = document.getElementById('chatLogsContainer');
                    if (currentContainer && currentContainer.innerHTML.trim() !== htmlContent.trim()) {

                        // Client side rendering extension safety hook
                        currentContainer.innerHTML = htmlContent;

                        // Re-parsing logic hook to fix extension checks dynamically on update
                        var items = currentContainer.querySelectorAll('.msg-content-text');
                        items.forEach(el => {
                            let text = el.textContent.trim();
                            let textLower = text.toLowerCase();
                            var isImg = (textLower.startsWith('/uploads/') || textLower.startsWith('http://') || textLower.startsWith('https://')) &&
                                         (textLower.endsWith('.jpg') || textLower.endsWith('.jpeg') || textLower.endsWith('.png') || textLower.endsWith('.gif'));
                            if (isImg && !el.querySelector('img')) {
                                el.innerHTML = `<img src="${text}" class="chat-image-attachment" alt="Transmission Attachment" onclick="zoomImage(this.src)" />`;
                            }
                        });

                        scrollToBottom(false);
                    }
                })
                .catch(error => {
                    fetch('/Chat/ViewChat?citizenPhone=' + citizenPhone)
                        .then(res => res.text())
                        .then(html => {
                            var parser = new DOMParser();
                            var doc = parser.parseFromString(html, 'text/html');
                            var newMessages = doc.getElementById('chatLogsContainer').innerHTML;
                            var currentContainer = document.getElementById('chatLogsContainer');
                            if (currentContainer && currentContainer.innerHTML.trim() !== newMessages.trim()) {
                                currentContainer.innerHTML = newMessages;
                                scrollToBottom(false);
                            }
                        });
                });
        }

        @if (!string.IsNullOrEmpty(currentCitizenPhone))
        {
                    <text>
                    setInterval(triggerBackgroundRefresh, 3000); // 3 seconds loop
                    </text>
        }

        // Zoom Image using SweetAlert2
        function zoomImage(imgSrc) {
            Swal.fire({
                imageUrl: imgSrc,
                imageAlt: 'Evidence Transmission',
                background: '#131026',
                showConfirmButton: false,
                showCloseButton: true,
                maxWidth: '80%'
            });
        }

        // Terminate Chat Room Handler
        function confirmDeleteChat(chatId, phone) {
            Swal.fire({
                title: 'Terminate Room?',
                text: "This will discard the entire communication workspace dashboard visibility!",
                icon: 'warning',
                background: '#131026',
                color: '#fff',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6c5ce7',
                confirmButtonText: 'Yes, Delete'
            }).then((result) => {
                if (result.isConfirmed) {
                    var form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '/Chat/DeleteChatRoom';

                    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    form.innerHTML = `
                        <input type="hidden" name="__RequestVerificationToken" value="${token}" />
                        <input type="hidden" name="chatId" value="${chatId}" />
                        <input type="hidden" name="citizenPhone" value="${phone}" />
                    `;
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
</body>
</html>