@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Citizen Profile - CrimeVision</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
            body {
                margin: 0;
                padding: 0;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background: radial-gradient(circle at center, #0f172a 0%, #020617 100%);
                color: #ffffff;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                padding: 20px 0;
                box-sizing: border-box;
            }

            .register-container {
                background: rgba(15, 23, 42, 0.6);
                border: 1px solid rgba(255, 255, 255, 0.05);
                border-radius: 24px;
                padding: 40px;
                width: 100%;
                max-width: 500px;
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
                backdrop-filter: blur(20px);
                box-sizing: border-box;
            }

            .brand-header {
                text-align: center;
                margin-bottom: 25px;
            }

            .brand-logo {
                font-size: 26px;
                font-weight: 700;
                color: #ffffff;
                margin-bottom: 6px;
            }

                .brand-logo span {
                    color: #06b6d4;
                }

            .brand-subtitle {
                color: #9ca3af;
                font-size: 13px;
                margin: 0;
            }

            .form-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 15px;
            }

            .full-width {
                grid-column: span 2;
            }

            .form-group {
                margin-bottom: 18px;
            }

                .form-group label {
                    display: block;
                    color: #9ca3af;
                    font-size: 11px;
                    margin-bottom: 6px;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                }

            .input-wrapper {
                position: relative;
            }

                .input-wrapper i {
                    position: absolute;
                    left: 15px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #06b6d4;
                    font-size: 14px;
                }

            .form-control {
                width: 100%;
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 12px;
                padding: 12px 15px 12px 42px;
                color: #ffffff;
                font-size: 14px;
                outline: none;
                transition: all 0.3s ease;
                box-sizing: border-box;
            }

                .form-control:focus {
                    border-color: #06b6d4;
                    box-shadow: 0 0 10px rgba(6, 182, 212, 0.2);
                }

            .btn-register {
                width: 100%;
                background: linear-gradient(90deg, #06b6d4 0%, #2563eb 100%);
                color: white;
                border: none;
                border-radius: 12px;
                padding: 14px;
                font-size: 14px;
                font-weight: 600;
                cursor: pointer;
                transition: all 0.3s ease;
                box-shadow: 0 4px 15px rgba(6, 182, 212, 0.3);
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-top: 10px;
            }

                .btn-register:hover {
                    transform: translateY(-1px);
                    box-shadow: 0 6px 20px rgba(6, 182, 212, 0.5);
                }

            .switch-prompt {
                text-align: center;
                margin-top: 20px;
                font-size: 13px;
                color: #9ca3af;
                grid-column: span 2;
            }

                .switch-prompt a {
                    color: #06b6d4;
                    text-decoration: none;
                    font-weight: 600;
                }

                    .switch-prompt a:hover {
                        text-decoration: underline;
                    }
    </style>
</head>
<body>

    <div class="register-container">
        <div class="brand-header">
            <div class="brand-logo"><i class="fa-solid fa-user-plus" style="color: #06b6d4; margin-right: 8px;"></i>Citizen<span>Registry</span></div>
            <p class="brand-subtitle">Create your secure decentralized civilian profile</p>
        </div>

        <form action="@Url.Action("UserRegister", "Account")" method="post">
            @Html.AntiForgeryToken()

            @if (ViewBag.Error != null)
            {
                <div style="color: #ef4444; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); padding: 12px; border-radius: 12px; font-size: 13px; margin-bottom: 20px; text-align: center; grid-column: span 2;">
                    <i class="fa-solid fa-circle-exclamation" style="margin-right: 6px;"></i> @ViewBag.Error
                </div>
            }

            <div class="form-grid">
            
                <div class="form-group full-width">
                    <label>Full Identity Name</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-user"></i>
                        <input type="text" name="FullName" class="form-control" placeholder="e.g. Hamza Ali" required />
                    </div>
                </div>

                <div class="form-group full-width">
                    <label>Email Address</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-envelope"></i>
                        <input type="email" name="Email" class="form-control" placeholder="name@example.com" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>CNIC (13 Digits)</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-id-card"></i>
                        <input type="text" name="CNIC" class="form-control" placeholder="37405XXXXXXXX" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Mobile Number</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-phone"></i>
                        <input type="text" name="PhoneNumber" class="form-control" placeholder="03XXXXXXXXX" required />
                    </div>
                </div>

                <div class="form-group full-width">
                    <label>Create Secure Password</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" name="Password" class="form-control" placeholder="••••••••" required />
                    </div>
                </div>

            </div>

            <button type="submit" class="btn-register">Create Secure Account</button>
        </form>

        <div class="switch-prompt">
            Already registered? <a href="@Url.Action("UserLogin", "Account")">Login Here</a>
        </div>
    </div>
</body>
</html>