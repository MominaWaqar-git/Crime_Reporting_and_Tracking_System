@model Crime_Reporting_and_Tracking_System.Models.User
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Citizen Profile - CrimeVision</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            body {
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                background: #050816;
                padding: 40px 0;
                color: white;
            }

            /* BACKGROUND NEON BLOBS */
            .blob {
                position: absolute;
                border-radius: 50%;
                filter: blur(120px);
                opacity: .6;
                z-index: 1;
            }

            .b1 {
                width: 500px;
                height: 500px;
                background: #2563eb;
                top: -150px;
                left: -150px;
            }

            .b2 {
                width: 500px;
                height: 500px;
                background: #9333ea;
                bottom: -150px;
                right: -150px;
            }

            /* CONTAINER BOX */
            .register-container {
                width: 100%;
                max-width: 520px;
                padding: 45px;
                border-radius: 30px;
                background: rgba(255, 255, 255, 0.06);
                border: 1px solid rgba(255, 255, 255, 0.08);
                backdrop-filter: blur(20px);
                box-shadow: 0 20px 50px rgba(0,0,0,.5);
                z-index: 2;
            }

                .register-container h2 {
                    text-align: center;
                    margin-bottom: 6px;
                    font-size: 30px;
                    font-weight: 600;
                }

            .brand-subtitle {
                color: #9ca3af;
                font-size: 13px;
                text-align: center;
                margin-bottom: 25px;
            }

            /* IMAGE AVATAR UPLOAD STYLES */
            .avatar-upload-container {
                display: flex;
                flex-direction: column;
                align-items: center;
                margin-bottom: 25px;
                grid-column: span 2;
            }

            .avatar-preview-wrapper {
                position: relative;
                width: 100px;
                height: 100px;
                border-radius: 50%;
                padding: 3px;
                background: linear-gradient(135deg, #2563eb, #9333ea);
                box-shadow: 0 0 20px rgba(37, 99, 235, 0.4);
                margin-bottom: 12px;
            }

                .avatar-preview-wrapper img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    border-radius: 50%;
                    background: #151828;
                }

            .avatar-hint {
                font-size: 11px;
                color: #cbd5e1;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 10px;
            }

            /* FORM FIELD LAYOUT GRID */
            .form-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 18px;
            }

            .full-width {
                grid-column: span 2;
            }

            .form-group label {
                display: block;
                color: #cbd5e1;
                font-size: 11px;
                margin-bottom: 6px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .input-box {
                position: relative;
            }

                .input-box input {
                    width: 100%;
                    padding: 13px 15px 13px 42px;
                    border-radius: 14px;
                    border: 1px solid rgba(255,255,255,0.1);
                    outline: none;
                    background: rgba(255,255,255,0.08);
                    color: white;
                    font-size: 14px;
                    transition: .3s;
                }

                    .input-box input:focus {
                        border-color: #60a5fa;
                        background: rgba(255, 255, 255, 0.12);
                    }

                .input-box i {
                    position: absolute;
                    left: 15px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #60a5fa;
                    font-size: 14px;
                }

                .input-box input[type="file"] {
                    padding: 11px 15px 11px 42px;
                    cursor: pointer;
                }

            /* BUTTON GRADIENT */
            .btn {
                width: 100%;
                padding: 15px;
                border: none;
                border-radius: 14px;
                background: linear-gradient(135deg, #2563eb, #9333ea);
                color: white;
                font-weight: 600;
                font-size: 14px;
                cursor: pointer;
                transition: .3s;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-top: 15px;
            }

                .btn:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3);
                }

            /* PREMIUM BACK BUTTON */
            .back-btn {
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 10px;
                margin-top: 15px;
                padding: 15px;
                border-radius: 14px;
                text-decoration: none;
                color: white;
                background: rgba(255,255,255,0.08);
                border: 1px solid rgba(255,255,255,0.1);
                font-weight: 500;
                font-size: 14px;
                transition: .3s;
            }

                .back-btn:hover {
                    transform: translateY(-3px);
                    background: rgba(255,255,255,0.15);
                    box-shadow: 0 10px 20px rgba(255, 255, 255, 0.05);
                }

            .switch-prompt {
                text-align: center;
                margin-top: 20px;
                font-size: 13px;
                color: #9ca3af;
                grid-column: span 2;
            }

                .switch-prompt a {
                    color: #60a5fa;
                    text-decoration: none;
                    font-weight: 600;
                }

                    .switch-prompt a:hover {
                        color: #a855f7;
                        text-decoration: underline;
                    }

            .error-container {
                color: #ff6b6b;
                background: rgba(255, 107, 107, 0.1);
                border: 1px solid rgba(255, 107, 107, 0.2);
                padding: 12px;
                border-radius: 12px;
                font-size: 13px;
                margin-bottom: 20px;
                text-align: center;
                grid-column: span 2;
            }
    </style>
</head>
<body>

    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <div class="register-container">
        <h2>Citizen Registry</h2>
        <p class="brand-subtitle">Create your secure decentralized civilian profile</p>

        <form action="@Url.Action("UserRegister", "Account")" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            @if (ViewBag.Error != null)
            {
                <div class="error-container">
                    <i class="fa-solid fa-circle-exclamation" style="margin-right: 6px;"></i> @ViewBag.Error
                </div>
            }

            <div class="form-grid">

                <div class="avatar-upload-container">
                    <div class="avatar-preview-wrapper">
                        <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png" id="avatarPreview" alt="Profile Preview" />
                    </div>
                    <span class="avatar-hint">Upload Profile Picture</span>
                    <div class="input-box" style="width: 100%;">
                        <i class="fa-solid fa-camera"></i>
                        <input type="file" name="ProfileImageFile" id="imageUploader" accept="image/*" />
                    </div>
                </div>

                <div class="form-group full-width">
                    <label>Full Identity Name</label>
                    <div class="input-box">
                        <i class="fa-solid fa-user"></i>
                        <input type="text" name="FullName" placeholder="e.g. Hamza Ali" required />
                    </div>
                </div>

                <div class="form-group full-width">
                    <label>Email Address</label>
                    <div class="input-box">
                        <i class="fa-solid fa-envelope"></i>
                        <input type="email" name="Email" placeholder="name@example.com" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>CNIC (13 Digits)</label>
                    <div class="input-box">
                        <i class="fa-solid fa-id-card"></i>
                        <input type="text" name="CNIC" placeholder="37405XXXXXXXX" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Mobile Number</label>
                    <div class="input-box">
                        <i class="fa-solid fa-phone"></i>
                        <input type="text" name="PhoneNumber" placeholder="03XXXXXXXXX" required />
                    </div>
                </div>

                <div class="form-group full-width">
                    <label>Create Secure Password</label>
                    <div class="input-box">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" name="Password" placeholder="••••••••" required />
                    </div>
                </div>

                <button type="submit" class="btn full-width">Create Secure Account</button>

                <a href="@Url.Action("Index", "Home")" class="back-btn full-width">
                    <i class="fa-solid fa-arrow-left"></i>
                    Back To Home
                </a>
            </div>
        </form>

        <div class="switch-prompt">
            Already registered? <a href="@Url.Action("UserLogin", "Account")">Login Here</a>
        </div>
    </div>

    <script>
            document.getElementById('imageUploader').addEventListener('change', function (event) {
                const [file] = this.files;
                if (file) {
                    document.getElementById('avatarPreview').src = URL.createObjectURL(file);
                }
            });
    </script>

</body>
</html>