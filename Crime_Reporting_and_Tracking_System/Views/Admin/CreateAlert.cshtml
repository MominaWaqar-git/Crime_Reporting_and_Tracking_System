@model Crime_Reporting_and_Tracking_System.Models.PublicAlert
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Broadcast Public Alert";
}

<style>
    /* Premium Futuristic Card Container matching standard layout */
    .form-wrapper {
        max-width: 850px;
        margin: 20px auto;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        padding: 40px;
        backdrop-filter: blur(25px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255,255,255,0.1);
        position: relative;
        overflow: hidden;
    }

        .form-wrapper::before {
            content: '';
            position: absolute;
            top: -150px;
            right: -150px;
            width: 300px;
            height: 300px;
            background: rgba(239, 68, 68, 0.15);
            filter: blur(100px);
            border-radius: 50%;
            pointer-events: none;
        }

    .form-header-desc {
        color: #9ca3af;
        font-size: 14px;
        margin-top: -5px;
        margin-bottom: 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 15px;
        text-align: left;
    }

    .form-group {
        margin-bottom: 25px;
        position: relative;
        text-align: left;
    }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            color: #f87171;
            font-weight: 600;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

    .form-control {
        width: 100%;
        padding: 14px 16px;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        color: #f3f4f6;
        font-size: 14px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-sizing: border-box;
    }

        .form-control:focus {
            border-color: #ef4444;
            background: rgba(0, 0, 0, 0.3);
            box-shadow: 0 0 18px rgba(239, 68, 68, 0.25);
            outline: none;
        }

    select.form-control option {
        background: #111827;
        color: #f3f4f6;
    }

    input[type="date"]::-webkit-calendar-picker-indicator {
        filter: invert(1) brightness(100%) contrast(100%);
        cursor: pointer;
    }

    .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    @@media (max-width: 600px) {
        .grid-2 {
            grid-template-columns: 1fr;
            gap: 0;
        }

        .action-row {
            flex-direction: column;
            gap: 15px;
        }
    }

    .file-upload-wrapper {
        border: 2px dashed rgba(239, 68, 68, 0.3);
        background: rgba(239, 68, 68, 0.02);
        border-radius: 14px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: 0.3s;
    }

        .file-upload-wrapper:hover {
            border-color: #ef4444;
            background: rgba(239, 68, 68, 0.05);
        }

        .file-upload-wrapper i {
            font-size: 26px;
            color: #ef4444;
            margin-bottom: 8px;
        }

    .text-danger {
        color: #f87171;
        font-size: 12px;
        margin-top: 6px;
        display: block;
        font-weight: 500;
    }

    .action-row {
        display: flex;
        gap: 20px;
        margin-top: 35px;
    }

    .btn-submit-cyber-alert {
        flex: 2;
        background: linear-gradient(90deg, #dc2626 0%, #ef4444 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 15px 30px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(220, 38, 38, 0.3);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-submit-cyber-alert:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(220, 38, 38, 0.5);
        }

    .btn-back-cyber {
        flex: 1;
        background: linear-gradient(90deg, #4b5563 0%, #1f2937 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 15px 25px;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-back-cyber:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5);
        }

    .status-error {
        padding: 14px;
        border-radius: 12px;
        font-size: 13px;
        margin-bottom: 20px;
        background: rgba(239, 68, 68, 0.1);
        color: #f87171;
        border: 1px solid rgba(239, 68, 68, 0.2);
        text-align: left;
    }
</style>

<div class="form-wrapper">
    <h3 style="color: white; margin: 0 0 8px 0; font-weight: 600; font-size: 22px; text-align: left;">
        <i class="fa-solid fa-triangle-exclamation" style="color: #ef4444; margin-right: 8px;"></i> Broadcast Public Security Alert
    </h3>
    <p class="form-header-desc">Issue emergency warnings or critical safety alerts directly to the civilian network.</p>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="status-error">
            <i class="fa-solid fa-circle-exclamation" style="margin-right: 6px;"></i> @ViewBag.ErrorMessage
        </div>
    }

    <form asp-action="CreateAlert" asp-controller="Admin" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Title">Alert Title</label>
                <input asp-for="Title" class="form-control" placeholder="e.g. Armed Robbery Warning" autocomplete="off" required />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="AlertLevel">Alert Level</label>
                <select asp-for="AlertLevel" class="form-control" required>
                    <option value="" disabled selected>Select Severity Level</option>
                    <option value="Low">Low</option>
                    <option value="Medium">Medium</option>
                    <option value="High">High</option>
                    <option value="Critical">Critical</option>
                </select>
                <span asp-validation-for="AlertLevel" class="text-danger"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Location">Location</label>
                <input asp-for="Location" class="form-control" placeholder="e.g. Kalar Chowk, Kahuta" autocomplete="off" required />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ExpiryDate">Expiry Date & Time</label>
                <input asp-for="ExpiryDate" type="datetime-local" class="form-control" required />
                <span asp-validation-for="ExpiryDate" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Description">Description / Incident Details</label>
            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter comprehensive security notification details here..." required></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <!-- Optional Image Upload -->
        <div class="form-group">
            <label>Upload Advisory Image</label>
            <div class="file-upload-wrapper" onclick="document.getElementById('alertUpload').click();">
                <i class="fa-solid fa-bullhorn"></i>
                <p id="uploadContainerText" style="margin: 0; color: #e5e7eb; font-size: 14px; font-weight: 500;">Click to upload alert attachment banner</p>
                <input type="file" id="alertUpload" name="AlertAttachment" style="display: none;" accept="image/*" onchange="document.getElementById('uploadContainerText').innerHTML = 'Selected: <span style=\'color: #ef4444;\'>' + this.files[0].name + '</span>';" />
            </div>
        </div>

        <div class="action-row">
            <a asp-action="AlertsList" asp-controller="Admin" class="btn-back-cyber">
                <i class="fa-solid fa-arrow-left"></i> Cancel
            </a>
            <button type="submit" class="btn-submit-cyber-alert">
                <i class="fa-solid fa-radio"></i> Publish Alert Now
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}