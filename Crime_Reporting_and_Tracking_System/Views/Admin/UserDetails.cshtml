@model Crime_Reporting_and_Tracking_System.Models.User
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Citizen Identity Monitor";
}

<style>
    .details-wrapper {
        max-width: 800px;
        margin: 40px auto;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(6, 182, 212, 0.15);
        border-radius: 24px;
        padding: 40px;
        backdrop-filter: blur(20px);
        box-shadow: 0 0 40px rgba(6, 182, 212, 0.05), inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .profile-badge-section {
        display: flex;
        align-items: center;
        gap: 25px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 30px;
        margin-bottom: 30px;
    }

    .large-profile-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #06b6d4;
        box-shadow: 0 0 20px rgba(6, 182, 212, 0.2);
    }

    .meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px 40px;
    }

    @@media (max-width: 600px) {
        .meta-grid

    {
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .profile-badge-section {
        flex-direction: column;
        text-align: center;
    }

    .action-footer {
        flex-direction: column;
    }

    }

    .meta-item {
        background: rgba(0,0,0,0.15);
        border-left: 3px solid #06b6d4;
        padding: 12px 16px;
        border-radius: 0 12px 12px 0;
    }

    .meta-label {
        font-size: 11px;
        color: #06b6d4;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .meta-value {
        font-size: 15px;
        color: #ffffff;
        font-weight: 500;
    }

    .status-pill {
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
        margin-top: 8px;
    }

    .sp-active {
        background: rgba(16, 185, 129, 0.15);
        color: #10b981;
        border: 1px solid #10b981;
    }

    .sp-suspended {
        background: rgba(239, 68, 68, 0.15);
        color: #ef4444;
        border: 1px solid #ef4444;
    }

    .action-footer {
        display: flex;
        gap: 15px;
        margin-top: 40px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 25px;
    }

    .btn-action-edit {
        flex: 1;
        background: linear-gradient(90deg, #06b6d4 0%, #2563eb 100%);
        color: white;
        text-decoration: none;
        padding: 14px;
        border-radius: 12px;
        text-align: center;
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: 0.3s;
    }

        .btn-action-edit:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(6, 182, 212, 0.3);
        }

    .btn-action-return {
        flex: 1;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        color: #9ca3af;
        text-decoration: none;
        padding: 14px;
        border-radius: 12px;
        text-align: center;
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: 0.3s;
    }

        .btn-action-return:hover {
            background: rgba(255,255,255,0.08);
            color: white;
        }
</style>

<div class="details-wrapper">

    <!-- Profile Header section -->
    <div class="profile-badge-section">
        <img src="~/@(string.IsNullOrEmpty(Model.ProfileImage) ? "uploads/default-avatar.png" : Model.ProfileImage)"
             class="large-profile-avatar"
             onerror="this.src='/uploads/default-avatar.png';" />

        <div>
            <h2 style="color: white; margin: 0; font-weight: 600; font-size: 24px; letter-spacing: 0.5px;">@Model.FullName</h2>
            <span style="color: #c084fc; font-weight: 600; font-size: 14px; text-transform: uppercase; letter-spacing: 1px;">Verified Citizen Profile Context</span>
            <br />
            @if (Model.Status == "Active")
            {
                <span class="status-pill sp-active">Active Registry</span>
            }
            else
            {
                <span class="status-pill sp-suspended">Suspended Node</span>
            }
        </div>
    </div>

    <!-- Data Display Grid Matrix -->
    <div class="meta-grid">
        <div class="meta-item">
            <div class="meta-label">System Identity Sequence ID</div>
            <div class="meta-value">#USR-00@(Model.Id)</div>
        </div>
        <div class="meta-item">
            <div class="meta-label">Biometric CNIC Number</div>
            <div class="meta-value" style="letter-spacing: 0.5px; font-family: monospace;">@Model.CNIC</div>
        </div>
        <div class="meta-item" style="grid-column: span 2;">
            <div class="meta-label">Secured Communications Email Node</div>
            <div class="meta-value" style="font-size: 14px;">@Model.Email</div>
        </div>
        <div class="meta-item" style="grid-column: span 2;">
            <div class="meta-label">Registered Contact Mobile Endpoint</div>
            <div class="meta-value">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "N/A" : Model.PhoneNumber)</div>
        </div>
        <div class="meta-item" style="grid-column: span 2;">
            <div class="meta-label">Current Authentication Status</div>
            <div class="meta-value" style="color: @(Model.Status == "Active" ? "#10b981" : "#ef4444");">
                @Model.Status - Access Rights Authorized
            </div>
        </div>
    </div>

    <!-- Action Buttons Row -->
    <div class="action-footer">
        <a href="@Url.Action("Users", "Admin")" class="btn-action-return">
            <i class="fa-solid fa-chevron-left"></i> Return to Registry
        </a>
        <a href="@Url.Action("EditUser", "Admin", new { id = Model.Id })" class="btn-action-edit">
            <i class="fa-solid fa-user-gear"></i> Modify This Context
        </a>
    </div>

</div>