@model IEnumerable<dynamic>

@{
    Layout = "_AdminLayout";
}

<style>
    /* Main Panel Box */
    .report-card {
        background: rgba(24, 21, 44, 0.7);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
    }

    /* Search Bar */
    .search-box {
        position: relative;
        width: 320px;
    }

        .search-box input {
            width: 100%;
            padding: 12px 15px 12px 40px;
            background: #131026;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            color: white;
            outline: none;
            font-size: 14px;
        }

        .search-box i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #888;
        }

    /* Table Styling */
    .report-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .report-table th {
            padding: 15px;
            color: #6c5ce7;
            font-weight: 600;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.05);
        }

        .report-table td {
            padding: 15px;
            font-size: 14px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            color: #e0e0e0;
            vertical-align: middle;
        }

        .report-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

    /* Citizen Profile Avatar Styling */
    .citizen-profile-box {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .avatar-container {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid rgba(108, 92, 231, 0.4);
        background: #1a1636;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    .avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .default-avatar-icon {
        color: #a29bfe;
        font-size: 18px;
    }

    .citizen-info div {
        margin-bottom: 2px;
    }

    /* Evidence Styling */
    .evidence-img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 10px;
        border: 2px solid rgba(255,255,255,0.08);
        transition: 0.3s ease;
    }

        .evidence-img:hover {
            transform: scale(1.05);
        }

    /* Glowing Badges */
    .badge {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        display: inline-block;
        text-transform: uppercase;
    }

    .badge-pending {
        background: rgba(253, 203, 110, 0.15);
        color: #fdcb6e;
        border: 1px solid rgba(253, 203, 110, 0.3);
    }

    .badge-progress {
        background: rgba(9, 132, 227, 0.15);
        color: #0984e3;
        border: 1px solid rgba(9, 132, 227, 0.3);
    }

    .badge-completed {
        background: rgba(46, 213, 115, 0.15);
        color: #2ed573;
        border: 1px solid rgba(46, 213, 115, 0.3);
        box-shadow: 0 0 12px rgba(46, 213, 115, 0.2);
    }

    /* Action Buttons */
    .btn-action {
        border: none;
        padding: 7px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        text-decoration: none;
    }

    .btn-approve {
        background: linear-gradient(45deg, #1e90ff, #00ecc6);
        color: white;
    }

    .btn-complete {
        background: linear-gradient(45deg, #2ed573, #7bed9f);
        color: white;
        box-shadow: 0 4px 10px rgba(46, 213, 115, 0.2);
    }

    .btn-action:hover:not(:disabled) {
        transform: translateY(-2px);
        opacity: 0.9;
    }

    .btn-action:disabled {
        background: #333 !important;
        color: #777 !important;
        cursor: not-allowed;
        box-shadow: none !important;
        transform: none !important;
    }

    /* Officer Dropdown & Tags */
    .officer-select {
        background: #131026;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.1);
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 12px;
        outline: none;
        width: 140px;
    }

        .officer-select:disabled {
            background: rgba(255,255,255,0.02);
            color: #555;
            border-color: rgba(255,255,255,0.02);
        }

    .btn-assign {
        background: #6c5ce7;
        color: white;
        border: none;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 12px;
        cursor: pointer;
        margin-left: 3px;
    }

        .btn-assign:disabled {
            background: #222;
            color: #555;
            cursor: not-allowed;
        }

    .officer-tag {
        display: inline-block;
        background: rgba(108, 92, 231, 0.15);
        color: #a29bfe;
        border: 1px solid rgba(108, 92, 231, 0.3);
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 11px;
        margin: 2px;
    }
</style>

<div class="main">

    <!-- Topbar -->
    <div class="topbar" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:25px;">

        <h2>Crime Reports Management</h2>

        <!-- Live Search -->
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>

            <input type="text"
                   id="liveSearch"
                   placeholder="Search complaints..." />
        </div>

    </div>

    <div class="report-card">

        <div class="table-responsive">

            <table class="report-table">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Reporter / Citizen</th>
                        <th>Crime Type</th>
                        <th>Location & Date</th>
                        <th>Evidence</th>
                        <th>Status</th>
                        <th>Assigned Officers</th>
                        <th style="text-align:center;">Actions</th>
                    </tr>
                </thead>

                <tbody id="complaintsTable">

                    @if (ViewBag.AllComplaints != null)
                    {
                        foreach (var item in ViewBag.AllComplaints)
                        {
                            bool isCompleted = item.Status.Contains("Completed");

                            <tr>

                                <!-- ID -->
                                <td>#@item.ID</td>

                                <!-- Citizen -->
                                <td>
                                    <div class="citizen-profile-box">

                                        <div class="avatar-container">

                                            @if (!string.IsNullOrEmpty(item.CitizenImage) &&
                                                                                (item.CitizenImage.StartsWith("/") ||
                                                                                item.CitizenImage.StartsWith("~") ||
                                                                                item.CitizenImage.StartsWith("http")))
                                            {
                                                <img src="@Url.Content(item.CitizenImage)"
                                                     class="avatar-img"
                                                     alt="Citizen"
                                                     onerror="this.onerror=null; this.src='/images/default-avatar.png';" />
                                            }
                                            else
                                            {
                                                <i class="fa-solid fa-user default-avatar-icon"></i>
                                            }

                                        </div>

                                        <div class="citizen-info">
                                            <div style="font-weight:600; color:#fff;">
                                                @(item.FullName ?? "Anonymous")
                                            </div>

                                            <div style="font-size:12px; color:#aaa;">
                                                <i class="fa-solid fa-phone"
                                                   style="font-size:10px; color:#6c5ce7;"></i>

                                                @(item.PhoneNumber ?? "N/A")
                                            </div>
                                        </div>

                                    </div>
                                </td>

                                <!-- Crime Type -->
                                <td>
                                    <strong style="color:#ff7675;">
                                        @item.CrimeType
                                    </strong>
                                </td>

                                <!-- Location -->
                                <td>
                                    <div>
                                        <i class="fa-solid fa-location-dot"
                                           style="color:#a29bfe; font-size:11px;"></i>

                                        @item.Location
                                    </div>

                                    <div style="font-size:12px; color:#888; margin-top:4px;">
                                        <i class="fa-solid fa-calendar-days"
                                           style="font-size:11px;"></i>

                                        @item.IncidentDate
                                    </div>
                                </td>

                                <!-- Evidence -->
                                <td>

                                    @if (!string.IsNullOrEmpty(item.EvidenceFile))
                                    {
                                        if (item.EvidenceFile.EndsWith(".jpg") ||
                                        item.EvidenceFile.EndsWith(".png") ||
                                        item.EvidenceFile.EndsWith(".jpeg") ||
                                        item.EvidenceFile.EndsWith(".gif"))
                                        {
                                            <a href="@Url.Content(item.EvidenceFile)" target="_blank">

                                                <img src="@Url.Content(item.EvidenceFile)"
                                                     class="evidence-img"
                                                     alt="Evidence" />

                                            </a>
                                        }
                                        else
                                        {
                                            <a href="@Url.Content(item.EvidenceFile)"
                                               target="_blank"
                                               class="btn-action btn-approve">

                                                <i class="fa-solid fa-file"></i>
                                                View File

                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color:#888; font-size:12px;">
                                            <i class="fa-solid fa-ban"></i>
                                            No Evidence
                                        </span>
                                    }

                                </td>

                                <!-- Status -->
                                <td>

                                    @if (isCompleted)
                                    {
                                        <span class="badge badge-completed">
                                            <i class="fa-solid fa-circle-check"></i>
                                            Closed
                                        </span>
                                    }
                                    else if (item.Status.Contains("Pending"))
                                    {
                                        <span class="badge badge-pending">
                                            <i class="fa-solid fa-clock"></i>
                                            @item.Status
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-progress">
                                            <i class="fa-solid fa-spinner fa-spin"></i>
                                            @item.Status
                                        </span>
                                    }

                                </td>

                                <!-- Officers -->
                                <td>

                                    <div style="margin-bottom:8px; max-width:180px;">

                                        @if (!string.IsNullOrEmpty(item.AssignedOfficers))
                                        {
                                            string[] officers = item.AssignedOfficers.Split(',');

                                            foreach (var officer in officers)
                                            {
                                                <span class="officer-tag">
                                                    <i class="fa-solid fa-user-shield"
                                                       style="font-size:9px;"></i>

                                                    @officer.Trim()
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span style="font-size:12px; color:#ff7675;">
                                                <i class="fa-solid fa-triangle-exclamation"></i>
                                                Unassigned
                                            </span>
                                        }

                                    </div>

                                    <!-- Assign Officer -->
                                    <form action="/Admin/AssignOfficer"
                                          method="post"
                                          style="display:flex; align-items:center;">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="complaintId"
                                               value="@item.ID" />

                                        <select name="officerId"
                                                class="officer-select"
                                                required
                                                @(isCompleted ? "disabled" : "")>

                                            <option value="">+ Assign Officer</option>

                                            @if (ViewBag.OfficersList != null)
                                            {
                                                foreach (var off in ViewBag.OfficersList)
                                                {
                                                    <option value="@off.Id">
                                                        @off.FullName
                                                    </option>
                                                }
                                            }

                                        </select>

                                        <button type="submit"
                                                class="btn-assign"
                                                @(isCompleted ? "disabled" : "")>

                                            <i class="fa-solid fa-plus"></i>

                                        </button>

                                    </form>

                                </td>

                                <!-- Actions -->
                                <td style="text-align:center;">

                                    <div style="display:flex; flex-direction:column; gap:8px; align-items:center;">

                                        @if (isCompleted)
                                        {
                                            <span style="color:#2ed573; font-size:13px; font-weight:600;">
                                                <i class="fas fa-check-double"></i>
                                                Case Resolved
                                            </span>
                                        }
                                        else
                                        {
                                            @if (item.Status.Contains("Pending"))
                                            {
                                                <form action="/Admin/ApproveComplaint"
                                                      method="post"
                                                      style="display:inline;">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="id"
                                                           value="@item.ID" />

                                                    <button type="submit"
                                                            class="btn-action btn-approve">

                                                        <i class="fa-solid fa-thumbs-up"></i>
                                                        Approve

                                                    </button>

                                                </form>
                                            }

                                            <form action="/Admin/CompleteComplaint"
                                                  method="post"
                                                  style="display:inline;">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="id"
                                                       value="@item.ID" />

                                                <button type="submit"
                                                        class="btn-action btn-complete">

                                                    <i class="fa-solid fa-box-archive"></i>
                                                    Complete

                                                </button>

                                            </form>
                                        }

                                    </div>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8"
                                style="text-align:center; color:#888; padding:30px 0;">

                                No active complaints found in registry.

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<!-- LIVE SEARCH SCRIPT -->
<script>

    document.getElementById("liveSearch")
        .addEventListener("keyup", function () {

            let value = this.value.toLowerCase();

            let rows = document.querySelectorAll("#complaintsTable tr");

            rows.forEach(function (row) {

                let text = row.innerText.toLowerCase();

                if (text.includes(value)) {
                    row.style.display = "";
                }
                else {
                    row.style.display = "none";
                }

            });

        });

</script>