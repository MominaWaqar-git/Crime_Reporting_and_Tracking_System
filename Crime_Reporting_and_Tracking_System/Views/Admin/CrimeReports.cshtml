@{
    Layout = null;
}<!DOCTYPE html><html lang="en"><head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CrimeVision Admin - Crime Reports</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body { background: radial-gradient(circle at 50% 50%, #1a153a, #0b071e); color: #fff; min-height: 100vh; display: flex; flex-direction: column; }
        
        /* HEADER */
        .header { display: flex; justify-content: space-between; align-items: center; padding: 15px 30px; background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
        .logo { font-size: 20px; font-weight: bold; letter-spacing: 1px; display: flex; align-items: center; gap: 10px; color: #fff; }
        .logo i { color: #8a2be2; text-shadow: 0 0 10px rgba(138, 43, 226, 0.5); }

        .container { display: flex; flex: 1; }

        /* MATCHING SIDEBAR */
        .sidebar { width: 240px; background: rgba(15, 12, 30, 0.6); backdrop-filter: blur(20px); border-right: 1px solid rgba(255, 255, 255, 0.05); padding: 20px 0; display: flex; flex-direction: column; }
        .menu { display: flex; flex-direction: column; gap: 5px; padding: 0 15px; }
        .menu a { display: flex; align-items: center; gap: 12px; padding: 12px 15px; color: #b3b3b3; text-decoration: none; border-radius: 10px; font-size: 15px; transition: all 0.3s ease; }
        .menu a i { width: 20px; font-size: 16px; text-align: center; }
        .menu a:hover { color: #fff; background: rgba(255, 255, 255, 0.05); }
        .menu a.active { background: linear-gradient(45deg, #6c5ce7, #a29bfe); color: #fff; box-shadow: 0 4px 15px rgba(108, 92, 231, 0.4); }

        /* MAIN CONTENT */
        .main { flex: 1; padding: 30px; display: flex; flex-direction: column; gap: 25px; background: rgba(255, 255, 255, 0.01); }
        .topbar { display: flex; justify-content: space-between; align-items: center; }
        .topbar h2 { font-size: 24px; font-weight: 600; letter-spacing: 0.5px; }
        
        /* MATCHING TABLES & PANELS */
        .report-card { background: rgba(24, 21, 44, 0.7); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 25px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3); }
        
        .table-responsive { width: 100%; overflow-x: auto; }
        .report-table { width: 100%; border-collapse: collapse; text-align: left; }
        .report-table th { padding: 15px; color: #6c5ce7; font-weight: 600; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 2px solid rgba(255, 255, 255, 0.05); }
        .report-table td { padding: 15px; font-size: 15px; border-bottom: 1px solid rgba(255, 255, 255, 0.05); color: #e0e0e0; }
        .report-table tbody tr:hover { background: rgba(255, 255, 255, 0.02); }

        /* GLOWING BADGES */
        .badge { padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; display: inline-block; }
        .badge-pending { background: rgba(253, 203, 110, 0.15); color: #fdcb6e; border: 1px solid rgba(253, 203, 110, 0.3); box-shadow: 0 0 10px rgba(253, 203, 110, 0.1); }
        .badge-progress { background: rgba(9, 132, 227, 0.15); color: #0984e3; border: 1px solid rgba(9, 132, 227, 0.3); box-shadow: 0 0 10px rgba(9, 132, 227, 0.1); }

        /* BUTTONS */
        .btn-approve { background: linear-gradient(45deg, #2ed573, #1e90ff); color: white; border: none; padding: 7px 16px; border-radius: 20px; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 12px rgba(46, 213, 115, 0.2); }
        .btn-approve:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(46, 213, 115, 0.4); }
        .approved-text { color: #2ed573; font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 6px; }

        /* FOOTER */
        .footer { text-align: center; padding: 20px; font-size: 13px; color: #666; background: rgba(0, 0, 0, 0.2); margin-top: auto; border-top: 1px solid rgba(255, 255, 255, 0.02); }
    </style></head><body>

    <div class="header">
        <div class="logo">
            <i class="fa-solid fa-shield-halved"></i> CrimeVision Admin
        </div>
    </div>

    <div class="container">
        <div class="sidebar">
            <div class="menu">
                <a href="/Admin/Dashboard"><i class="fa-solid fa-gauge"></i> Dashboard</a>
                <a href="/Admin/CrimeReports" class="active"><i class="fa-solid fa-file"></i> Crime Reports</a>
                <a href="/Admin/Users"><i class="fa-solid fa-users"></i> Users</a>
                <a href="#"><i class="fa-solid fa-user-shield"></i> Officers</a>
                <a href="/Account/AdminLogin"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
            </div>
        </div>

        <div class="main">
            <div class="topbar">
                <h2>Crime Reports Management</h2>
            </div>

            <div class="report-card">
                <div class="table-responsive">
                    <table class="report-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Citizen Name</th>   <th>Contact Number</th> <th>Crime Type</th>
                                <th>Location</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.AllComplaints != null)
                            {
                                foreach (var item in ViewBag.AllComplaints)
                                {
                                    <tr>
                                        <td>#@item.ID</td>
                                        
                                        <td><i class="fa-solid fa-user text-muted style="font-size: 13px;" me-1"></i> @(item.FullName ?? "N/A")</td>
                                        <td><i class="fa-solid fa-phone text-muted style="font-size: 13px;" me-1"></i> @(item.PhoneNumber ?? "N/A")</td>
                                        
                                        <td><strong>@item.CrimeType</strong></td>
                                        <td>@item.Location</td>
                                        <td>@item.IncidentDate</td>
                                        <td>
                                            @if (item.Status.Contains("Pending"))
                                            {
                                                <span class="badge badge-pending">@item.Status</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-progress">@item.Status</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.Status.Contains("Pending"))
                                            {
                                                <form action="/Admin/ApproveComplaint" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@item.ID" />
                                                    <button type="submit" class="btn-approve">Approve Request</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="approved-text"><i class="fas fa-check-circle"></i> In Progress</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" style="text-align: center; color: #888; padding: 30px 0;">No active complaints found in registry.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="footer">
        © 2026 CrimeVision | Smart Crime Reporting & Tracking System
    </div></body></html>