@model IEnumerable<Crime_Reporting_and_Tracking_System.Models.User>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Citizens Registry";
}

<style>
    .dashboard-container {
        max-width: 1200px;
        margin: 20px auto;
        padding: 0 15px;
    }

    .registry-wrapper {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(20px);
    }

    .registry-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 20px;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .header-left h3 {
        color: white;
        margin: 0;
        font-weight: 600;
        font-size: 22px;
    }

    .header-left p {
        color: #9ca3af;
        margin: 5px 0 0 0;
        font-size: 13px;
    }

    /* RIGHT SIDE CONTROLS */
    .header-actions {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    /* SAME STYLE AS OFFICERS BUTTON */
    .btn-add-cyber {
        background: linear-gradient(90deg, #06b6d4 0%, #2563eb 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(6, 182, 212, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .btn-add-cyber:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(6, 182, 212, 0.5);
        }

    /* SEARCH BOX */
    .search-box {
        position: relative;
        width: 260px;
    }

        .search-box input {
            width: 100%;
            padding: 11px 15px 11px 42px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.04);
            color: white;
            outline: none;
            transition: 0.3s;
            font-size: 14px;
        }

            .search-box input:focus {
                border-color: #06b6d4;
                box-shadow: 0 0 15px rgba(6,182,212,0.3);
            }

            .search-box input::placeholder {
                color: #94a3b8;
            }

        .search-box i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #06b6d4;
            font-size: 14px;
        }

    .cyber-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .cyber-table th {
            background: rgba(255, 255, 255, 0.03);
            color: #06b6d4;
            padding: 14px;
            font-size: 13px;
            text-transform: uppercase;
            border-bottom: 2px solid rgba(6, 182, 212, 0.3);
        }

        .cyber-table td {
            padding: 14px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            color: #e5e7eb;
            font-size: 14px;
        }

        .cyber-table tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

    .citizen-thumb {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #06b6d4;
        box-shadow: 0 0 10px rgba(6,182,212,0.2);
    }

    .badge-status {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-active {
        background: rgba(16,185,129,0.15);
        color: #10b981;
        border: 1px solid #10b981;
    }

    .badge-suspended {
        background: rgba(239,68,68,0.15);
        color: #ef4444;
        border: 1px solid #ef4444;
    }

    /* ACTION ICONS */
    .action-icons a {
        margin-right: 12px;
        font-size: 16px;
        transition: 0.3s;
        text-decoration: none;
    }

        .action-icons a:hover {
            transform: scale(1.15);
        }

    .edit-icon {
        color: #a855f7;
    }

    .view-icon {
        color: #60a5fa;
    }

    .delete-icon {
        color: #f87171;
    }
</style>

<div class="dashboard-container">
    <div class="registry-wrapper">

        <div class="registry-header">

            <!-- LEFT -->
            <div class="header-left">
                <h3>
                    <i class="fa-solid fa-users-viewfinder"
                       style="color:#06b6d4; margin-right:8px;"></i>
                    Citizens System Registry
                </h3>

                <p>
                    Central database tracking authorized civilian identity profiles.
                </p>
            </div>

            <!-- RIGHT -->
            <div class="header-actions">

                <!-- SEARCH -->
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>

                    <input type="text"
                           id="liveSearch"
                           placeholder="Search any citizen data..." />
                </div>

                <!-- BUTTON -->
                <a href="@Url.Action("CreateUser", "Admin")"
                   class="btn-add-cyber">

                    <i class="fa-solid fa-user-plus"></i>
                    Add New Citizen
                </a>

            </div>

        </div>

        <div style="overflow-x:auto;">

            <table class="cyber-table">

                <thead>
                    <tr>
                        <th>Avatar</th>
                        <th>Citizen Name</th>
                        <th>Email Address</th>
                        <th>Mobile Number</th>
                        <th>CNIC</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody id="citizenTable">

                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="7"
                                style="text-align:center;
                                           color:#6b7280;
                                           padding:40px;">

                                No records found in CrimeVision database registry.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <!-- IMAGE -->
                                <td>
                                    <img src="~/@(string.IsNullOrEmpty(item.ProfileImage)
                                                                             ? "uploads/default-avatar.png"
                                                                             : item.ProfileImage)"
                                                                                                 class="citizen-thumb"
                                                                                                 onerror="this.src='/uploads/default-avatar.png';" />
                                                                                        </td>

                                <!-- NAME -->
                                <td style="font-weight:600; color:white;">
                                    @item.FullName
                                </td>

                                <!-- EMAIL -->
                                <td>
                                    @item.Email
                                </td>

                                <!-- PHONE -->
                                <td>
                                    @(string.IsNullOrEmpty(item.PhoneNumber)
                                                                ? "N/A"
                                                                : item.PhoneNumber)
                        </td>

                                <!-- CNIC -->
                                <td>
                                    @item.CNIC
                                </td>

                                <!-- STATUS -->
                                <td>

                            @if (item.Status == "Active")
                                    {
                                        <span class="badge-status badge-active">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-status badge-suspended">
                                            Suspended
                                        </span>
                                    }

                                </td>

                                <!-- ACTIONS -->
                                <td class="action-icons">

                                    <a href="@Url.Action("EditUser", "Admin",
                                                                              new { id = item.Id })"
                               title="Edit">

                                        <i class="fa-solid fa-pen-to-square edit-icon"></i>
                                    </a>

                                    <a href="@Url.Action("UserDetails", "Admin",
                                                                      new { id = item.Id })"
                               title="View">

                                        <i class="fa-solid fa-eye view-icon"></i>
                                    </a>

                                    <a href="@Url.Action("DeleteUser", "Admin",
                                                                      new { id = item.Id })"
                               onclick="return confirm('Are you sure to delete this citizen?');"
                               title="Delete">

                                        <i class="fa-solid fa-trash delete-icon"></i>
                                    </a>

                                </td>

                            </tr>
                                        }
                    }

                </tbody>

            </table>

        </div>

    </div>
</div>

<!-- LIVE SEARCH SCRIPT -->
<script>

    document.getElementById("liveSearch")
        .addEventListener("keyup", function () {

            let value = this.value.toLowerCase();

            let rows = document.querySelectorAll("#citizenTable tr");

            rows.forEach(function (row) {

                let rowText = row.innerText.toLowerCase();

                if (rowText.includes(value)) {
                    row.style.display = "";
                }
                else {
                    row.style.display = "none";
                }

            });

        });

</script>