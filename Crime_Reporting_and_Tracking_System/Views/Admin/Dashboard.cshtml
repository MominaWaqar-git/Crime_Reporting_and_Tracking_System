@using System.Text.Json

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Admin Dashboard</title>

    <!-- FONT -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- ICONS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <!-- CHART JS -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>

        :root {
            --blue: #2563eb;
            --purple: #9333ea;
            --cyan: #06b6d4;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            min-height: 100vh;
            background: #050816;
            color: white;
            overflow-x: hidden;
        }

        /* BACKGROUND BLUR BLOBS */
        .blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(120px);
            opacity: .6;
            z-index: 0;
        }

        .b1 {
            width: 450px;
            height: 450px;
            background: var(--blue);
            top: -120px;
            left: -120px;
        }

        .b2 {
            width: 450px;
            height: 450px;
            background: var(--purple);
            bottom: -120px;
            right: -120px;
        }

        /* HEADER */
        .header {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 18px 8%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(25px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            z-index: 10;
        }

            .header::after {
                content: "";
                position: absolute;
                bottom: 0;
                left: 0;
                height: 2px;
                width: 100%;
                background: linear-gradient(90deg, var(--blue), var(--purple), var(--cyan));
                opacity: 0.8;
            }

        .logo {
            font-size: 22px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .logo i {
                color: #60a5fa;
            }

        /* LAYOUT */
        .container {
            display: flex;
            margin-top: 80px;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            min-height: calc(100vh - 80px);
            padding: 20px;
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255,255,255,0.08);
            z-index: 2;
        }

        .menu a {
            position: relative;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px;
            margin: 10px 0;
            color: white;
            text-decoration: none;
            border-radius: 12px;
            transition: .3s;
            overflow: hidden;
        }

            .menu a::before {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(90deg, rgba(37,99,235,0.25), rgba(147,51,234,0.25));
                opacity: 0;
                transition: .3s;
            }

            .menu a:hover::before {
                opacity: 1;
            }

            .menu a:hover {
                transform: translateX(8px);
                box-shadow: 0 0 20px rgba(99,102,241,0.25);
                background: rgba(255,255,255,0.06);
            }

            .menu a.active {
                background: linear-gradient(90deg, var(--blue), var(--purple));
            }

        /* MAIN */
        .main {
            flex: 1;
            padding: 30px;
            z-index: 2;
        }

        /* TOPBAR */
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .admin-box {
            padding: 10px 15px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            backdrop-filter: blur(15px);
        }

        /* CARDS */
        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
        }

        .card {
            position: relative;
            padding: 20px;
            border-radius: 18px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(18px);
            transition: .4s;
            overflow: hidden;
        }

            .card:hover {
                transform: translateY(-10px) scale(1.03);
                box-shadow: 0 0 25px rgba(37,99,235,0.4), 0 0 50px rgba(147,51,234,0.2);
            }

            .card::after {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle, rgba(99,102,241,0.2), transparent 60%);
                opacity: 0;
                transition: .4s;
            }

            .card:hover::after {
                opacity: 1;
            }

            .card i {
                font-size: 28px;
                color: #60a5fa;
                margin-bottom: 10px;
                transition: .3s;
            }

            .card:hover i {
                color: var(--purple);
                transform: scale(1.2);
            }

            .card h3 {
                font-size: 28px;
                margin-bottom: 5px;
            }

            .card p {
                color: #cbd5e1;
            }

        /* CHARTS */

        .charts {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            margin-top: 30px;
        }

        .chart-box {
            padding: 20px;
            border-radius: 18px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(18px);
        }

        canvas {
            width: 100% !important;
            height: 350px !important;
        }

        @@media(max-width:900px) {

            .charts {
                grid-template-columns: 1fr;
            }
        }

        /* FOOTER */
        .footer {
            position: fixed;
            bottom: 0;
            width: 100%;
            text-align: center;
            padding: 12px;
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(20px);
            border-top: 1px solid rgba(255,255,255,0.08);
        }

    </style>
</head>

<body>

    <!-- BACKGROUND -->
    <div class="blob b1"></div>
    <div class="blob b2"></div>

    <!-- HEADER -->
    <div class="header">
        <div class="logo">
            <i class="fa-solid fa-shield-halved"></i>
            CrimeVision Admin
        </div>
    </div>

    <div class="container">

        <!-- SIDEBAR -->
        <div class="sidebar">
            <div class="menu">

                <a class="active" href="#">
                    <i class="fa-solid fa-gauge"></i> Dashboard
                </a>

                <a href="/Admin/CrimeReports">
                    <i class="fa-solid fa-file"></i> Crime Reports
                </a>

                <a href="/Admin/Users">
                    <i class="fa-solid fa-users"></i> Users
                </a>

                <a href="/Officers" class="nav-link">
                    <i class="fa-solid fa-users"></i> Officers
                </a>

                <a asp-action="AlertsList" asp-controller="Admin">
                    <i class="fa-solid fa-triangle-exclamation"></i> Broadcast Alert
                </a>

                <a href="@Url.Action("AdminLogin", "Account")">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>

            </div>
        </div>

        <!-- MAIN -->
        <div class="main">

            <div class="topbar">

                <h2>Dashboard Overview</h2>

                <div class="admin-box">
                    Welcome, @Context.Session.GetString("Admin")
                </div>

            </div>

            <!-- DYNAMIC CARDS -->

            <div class="cards">

                <div class="card">
                    <i class="fa-solid fa-file"></i>
                    <h3>@ViewBag.TotalReports</h3>
                    <p>Total Reports</p>
                </div>

                <div class="card">
                    <i class="fa-solid fa-clock"></i>
                    <h3>@ViewBag.PendingCases</h3>
                    <p>Pending Cases</p>
                </div>

                <div class="card">
                    <i class="fa-solid fa-circle-check"></i>
                    <h3>@ViewBag.ResolvedCases</h3>
                    <p>Resolved</p>
                </div>

                <div class="card">
                    <i class="fa-solid fa-user"></i>
                    <h3>@ViewBag.TotalUsers</h3>
                    <p>Users</p>
                </div>

            </div>

            <!-- CHARTS -->

            <div class="charts">

                <!-- BAR CHART -->

                <div class="chart-box">

                    <h3 style="margin-bottom:20px;">
                        Monthly Crime Reports
                    </h3>

                    <canvas id="crimeChart"></canvas>

                </div>

                <!-- PIE CHART -->

                <div class="chart-box">

                    <h3 style="margin-bottom:20px;">
                        Case Status
                    </h3>

                    <canvas id="statusChart"></canvas>

                </div>

            </div>

        </div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        © 2026 CrimeVision | Smart Crime Reporting & Tracking System
    </div>

    ```cshtml
    <script>

        // ================= BAR CHART =================

        const crimeChart = new Chart(
            document.getElementById('crimeChart'),
            {
                type: 'bar',
                data: {
                    labels: @Html.Raw(JsonSerializer.Serialize((List<string>)ViewBag.CrimeTypes)),
                    datasets: [{
                        label: 'Crime Reports',
                        data: @Html.Raw(JsonSerializer.Serialize((List<int>)ViewBag.CrimeTotals)),

                        // NEW COLORS

                        backgroundColor: [
                            '#ff6b6b',
                            '#feca57',
                            '#1dd1a1',
                            '#54a0ff',
                            '#5f27cd',
                            '#ee5253',
                            '#10ac84',
                            '#341f97'
                        ],

                        borderRadius: 12,
                        borderSkipped: false
                    }]
                },

                options: {

                    responsive: true,

                    plugins: {

                        legend: {
                            labels: {
                                color: 'white',
                                font: {
                                    size: 14
                                }
                            }
                        }
                    },

                    scales: {

                        y: {
                            ticks: {
                                color: 'white',
                                font: {
                                    size: 13
                                }
                            },

                            grid: {
                                color: 'rgba(255,255,255,0.1)'
                            }
                        },

                        x: {
                            ticks: {
                                color: 'white',
                                font: {
                                    size: 13
                                }
                            },

                            grid: {
                                color: 'rgba(255,255,255,0.05)'
                            }
                        }
                    }
                }
            }
        );



        // ================= PIE CHART =================

        const statusChart = new Chart(
            document.getElementById('statusChart'),
            {
                type: 'doughnut',

                data: {

                    labels: ['Pending', 'Resolved', 'In Progress'],

                    datasets: [{
                        data: [
                            @ViewBag.PendingCases,
                            @ViewBag.ResolvedCases,
                            @ViewBag.InProgressCases
                        ],

                        backgroundColor: [
                            '#f39c12',
                            '#2ecc71',
                            '#3498db'
                        ],

                        borderWidth: 2,
                        borderColor: '#111827'
                    }]
                },

                options: {

                    responsive: true,

                    plugins: {

                        // WHITE TEXT

                        legend: {

                            position: 'bottom',

                            labels: {

                                color: 'white',

                                padding: 20,

                                font: {
                                    size: 14,
                                    weight: 'bold'
                                }
                            }
                        }
                    }
                }
            }
        );

    </script>

</body>
</html>